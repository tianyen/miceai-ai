# MICE-AI  - 環境變數配置範例
# 複製此文件為 .env 並修改相應的值

# ===== 服務器配置 =====
# HTTP 服務器端口
PORT=3000

# HTTPS 服務器端口
HTTPS_PORT=3443

# 運行環境 (development, production, test)
NODE_ENV=development

# ===== 應用程式配置 =====
# 應用程式基礎 URL（用於生成 QR Code 和外部連結）
BASE_URL=http://localhost:3000

# 應用程式名稱
APP_NAME=MICE-AI 

# ===== 資料庫配置 =====
# SQLite 資料庫文件路徑
DATABASE_PATH=./data/mice_ai.db

# ===== Session 配置 =====
# Session 密鑰（生產環境請使用強密碼）
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Session 過期時間（毫秒）
SESSION_MAX_AGE=86400000

# ===== JWT 配置 =====
# JWT 密鑰（用於 API Token 驗證，生產環境請使用強密碼）
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# ===== 安全配置 =====
# CORS 允許的來源（逗號分隔多個域名）
# 開發環境會自動允許所有來源，此設定主要用於生產環境
CORS_ORIGIN=http://localhost:3000,https://localhost:3000,http://localhost:9999,http://localhost:9998,https://localhost:3443,https://tianyen-service.com:4037,https://moon2025.tianyen-service.com,https://backend-0032.miceai.ai,https://event-0032.miceai.ai

# API 限流配置（管理後台 API）
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=500

# 前端 API 限流配置（公開 API，較寬鬆）
FRONTEND_API_RATE_LIMIT_WINDOW_MS=900000
FRONTEND_API_RATE_LIMIT_MAX_REQUESTS=1000

# ===== 文件上傳配置 =====
# 最大文件大小
MAX_FILE_SIZE=10mb

# ===== 日誌配置 =====
# 日誌級別 (DEBUG, INFO, WARN, ERROR)
# - DEBUG: 詳細的調試資訊（開發環境推薦）
# - INFO: 一般資訊性訊息（生產環境推薦）
# - WARN: 警告訊息
# - ERROR: 只記錄錯誤
LOG_LEVEL=INFO

# ===== Swagger 配置 =====
# Swagger UI 標題
SWAGGER_TITLE=MICE-AI  API

# Swagger 描述
SWAGGER_DESCRIPTION=MICE-AI 的 RESTful API 文件，包含管理後台和前端 API

# Swagger 版本
SWAGGER_VERSION=1.0.0

# ===== 生產環境配置 =====
# 生產環境域名（用於 Swagger 和 CORS）
PRODUCTION_DOMAIN=https://your-production-domain.com

# ===== Email 配置 (Google SMTP) =====
# SMTP 伺服器設定
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Gmail 帳號設定
# 注意：需要使用「應用程式密碼」而非一般密碼
# 1. 前往 Google 帳戶 → 安全性 → 兩步驟驗證
# 2. 啟用後選擇「應用程式密碼」
# 3. 產生一組 16 位密碼用於此處
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# 寄件者資訊
SMTP_FROM_NAME=MICE-AI 活動系統
SMTP_FROM_EMAIL=noreply@your-domain.com

# 是否啟用郵件功能（開發環境可設為 false）
SMTP_ENABLED=false

# ===== 開發配置 =====
# 是否啟用開發模式日誌
ENABLE_DEV_LOGS=true

# 是否啟用 API 調試日誌
ENABLE_API_DEBUG=true

# 是否啟用 console.log 輸出
ENABLE_CONSOLE_LOG=true

# ===== 功能模組開關 =====
# 專案詳情頁面的可選功能模組
# 設為 true 啟用，設為 false 或留空隱藏

# 問卷功能
FEATURE_QUESTIONNAIRES=false

# QR Code 名片功能
FEATURE_BUSINESS_CARDS=false

# 遊戲設定功能
FEATURE_GAMES=false

# 攤位設定功能
FEATURE_BOOTHS=false
