			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// 儲存 card_id 供後續請求使用",
							"if (pm.response.code === 200) {",
							"    const jsonData = pm.response.json();",
							"    if (jsonData.success && jsonData.data.card_id) {",
							"        pm.environment.set(\"cardId\", jsonData.data.card_id);",
							"        console.log(\"Card ID saved:\", jsonData.data.card_id);",
							"    }",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
