		{
			"name": "5. 🎯 提交活動報名（核心功能）",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// 測試回應狀態",
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"// 測試回應格式",
							"pm.test(\"Response has success field\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('success');",
							"    pm.expect(jsonData.success).to.be.true;",
							"});",
							"",
							"// 保存 trace_id 供後續測試使用",
							"pm.test(\"Save trace_id for subsequent tests\", function () {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.success && jsonData.data && jsonData.data.trace_id) {",
							"        pm.environment.set(\"traceId\", jsonData.data.trace_id);",
							"        console.log(\"Saved trace_id: \" + jsonData.data.trace_id);",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"{{participantName}}\",\n  \"email\": \"{{participantEmail}}\",\n  \"phone\": \"{{participantPhone}}\",\n  \"company\": \"{{participantCompany}}\",\n  \"position\": \"{{participantPosition}}\",\n  \"data_consent\": true,\n  \"marketing_consent\": false\n}"
				},
