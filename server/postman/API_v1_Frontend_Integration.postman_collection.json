	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// 生成隨機測試數據",
					"const timestamp = Date.now();",
					"const randomNum = Math.floor(Math.random() * 1000);",
					"",
					"// 設置測試用的參與者資料",
					"pm.environment.set(\"participantName\", `測試用戶${randomNum}`);",
					"pm.environment.set(\"participantEmail\", `test${timestamp}@example.com`);",
					"pm.environment.set(\"participantPhone\", `091234${randomNum.toString().padStart(4, '0')}`);",
					"pm.environment.set(\"participantCompany\", `測試公司${randomNum}`);",
					"pm.environment.set(\"participantPosition\", \"軟體工程師\");"
				]
			}
		}
