{{!-- 儀表板頁面 --}}

<div class="content-header">
    <h1>儀表板</h1>
    <p>系統概況和快速操作</p>
</div>

<!-- 統計卡片 -->
<div class="stats-grid" id="stats-grid">
    <div class="stat-card primary">
        <div class="stat-value" id="total-projects">-</div>
        <div class="stat-label">總MICE-AI 項目</div>
        <div class="stat-change" id="projects-change">無資料</div>
    </div>

    <div class="stat-card warning">
        <div class="stat-value" id="active-projects">-</div>
        <div class="stat-label">活躍項目</div>
        <div class="stat-change" id="active-projects-change">無資料</div>
    </div>

    <div class="stat-card danger">
        <div class="stat-value" id="total-users">-</div>
        <div class="stat-label">系統用戶</div>
        <div class="stat-change" id="users-change">無資料</div>
    </div>

    <div class="stat-card success">
        <div class="stat-value" id="email-sent-total">-</div>
        <div class="stat-label">已發送邀請信</div>
        <div class="stat-change" id="email-sent-today">今日 0 封</div>
    </div>
</div>

<div class="dashboard-grid">
    <!-- 最新項目 -->
    <div class="dashboard-card">
        <div class="card-header">
            <h3>最新項目</h3>
            <a href="/admin/projects" class="btn btn-sm btn-primary">
                查看全部
            </a>
        </div>
        <div class="card-content" id="recent-projects">
            <p class="text-center text-muted">暫無項目記錄</p>
        </div>
    </div>

    <!-- 系統活動 -->
    <div class="dashboard-card">
        <div class="card-header">
            <h3>系統活動</h3>
            <a href="/admin/logs" class="btn btn-sm btn-secondary">
                查看日誌
            </a>
        </div>
        <div class="card-content" id="recent-activities">
            <p class="text-center text-muted">暫無活動記錄</p>
        </div>
    </div>
</div>

<!-- 模態框容器 -->
<div id="modal-container"></div>
