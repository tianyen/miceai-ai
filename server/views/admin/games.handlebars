{{!-- 遊戲管理頁面 --}}

<div class="content-header">
    <h1>遊戲管理</h1>
    <p>管理遊戲庫、遊戲版本和遊戲狀態</p>
</div>

<!-- 操作按鈕 -->
<div class="action-bar">
    <div class="search-box">
        <input type="text" id="search-input" name="search" class="form-control" placeholder="搜尋遊戲名稱...">
        <button class="btn btn-primary" type="button" id="search-btn">
            <i class="fas fa-search"></i> 搜尋
        </button>
    </div>
    <div class="action-buttons">
        <button class="btn btn-success" id="new-game-btn">
            <i class="fas fa-plus"></i> 新增遊戲
        </button>
        <button class="btn btn-secondary" id="refresh-btn">
            <i class="fas fa-sync-alt"></i> 重新整理
        </button>
    </div>
</div>

<!-- 篩選器 -->
<div class="filter-bar">
    <div class="filter-group">
        <label for="status-filter">狀態篩選：</label>
        <select id="status-filter" name="status-filter" class="form-control">
            <option value="">所有狀態</option>
            <option value="1">啟用</option>
            <option value="0">停用</option>
        </select>
    </div>
</div>

<!-- 遊戲列表 -->
<div class="data-table-container">
    <div class="table-header">
        <h3>遊戲列表</h3>
        <div class="table-stats">
            <span class="stat-item">總遊戲：<strong id="total-games">-</strong></span>
            <span class="stat-item">啟用：<strong id="active-games">-</strong></span>
            <span class="stat-item">停用：<strong id="inactive-games">-</strong></span>
        </div>
    </div>

    <div class="table-content">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>中文名稱</th>
                    <th>英文名稱</th>
                    <th>遊戲 URL</th>
                    <th>版本</th>
                    <th>狀態</th>
                    <th>建立時間</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody id="games-table-body">
                <tr>
                    <td colspan="8" class="loading-cell">
                        <div class="loading-spinner"></div>
                        載入遊戲數據中...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- 分頁 -->
    <div class="pagination-container" id="pagination-container">
        <div class="pagination-info">
            <span>載入分頁資訊中...</span>
        </div>
    </div>
</div>

<!-- 模態框容器 -->
<div id="modal-container"></div>

<style>
.game-url {
    max-width: 300px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.game-url a {
    color: #007bff;
    text-decoration: none;
}

.game-url a:hover {
    text-decoration: underline;
}

.game-status {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
}

.game-status.active {
    background-color: #d4edda;
    color: #155724;
}

.game-status.inactive {
    background-color: #f8d7da;
    color: #721c24;
}

.game-version {
    font-family: 'Courier New', monospace;
    background-color: #f8f9fa;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 12px;
}

</style>

<script>
let currentPage = 1;
let currentLimit = 20;
let currentSearch = '';
let currentStatus = '';

// 頁面載入時執行
document.addEventListener('DOMContentLoaded', function() {
    loadGames();
    
    // 搜尋按鈕
    document.getElementById('search-btn').addEventListener('click', function() {
        currentSearch = document.getElementById('search-input').value;
        currentPage = 1;
        loadGames();
    });
    
    // Enter 鍵搜尋
    document.getElementById('search-input').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            currentSearch = this.value;
            currentPage = 1;
            loadGames();
        }
    });
    
    // 狀態篩選
    document.getElementById('status-filter').addEventListener('change', function() {
        currentStatus = this.value;
        currentPage = 1;
        loadGames();
    });
    
    // 新增遊戲按鈕
    document.getElementById('new-game-btn').addEventListener('click', function() {
        showGameModal();
    });
    
    // 重新整理按鈕
    document.getElementById('refresh-btn').addEventListener('click', function() {
        loadGames();
    });
});

// 載入遊戲列表
function loadGames() {
    const params = new URLSearchParams({
        page: currentPage,
        limit: currentLimit,
        search: currentSearch,
        is_active: currentStatus
    });

    // P1-7: 更新 API 端點
    fetch(`/api/admin/games?${params}`)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                renderGamesTable(data.data);
                renderPagination(data.pagination);
                updateStats(data.data);
            } else {
                showNotification('載入遊戲列表失敗', 'error');
            }
        })
        .catch(error => {
            console.error('載入遊戲列表失敗:', error);
            showNotification('載入遊戲列表失敗', 'error');
        });
}

// 渲染遊戲表格
function renderGamesTable(games) {
    const tbody = document.getElementById('games-table-body');
    
    if (games.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center">無符合條件的遊戲</td></tr>';
        return;
    }
    
    let html = '';
    games.forEach(game => {
        const statusClass = game.is_active ? 'active' : 'inactive';
        const statusText = game.is_active ? '啟用' : '停用';
        const createdAt = new Date(game.created_at).toLocaleString('zh-TW');
        
        html += `
        <tr>
            <td>${game.id}</td>
            <td>${game.game_name_zh}</td>
            <td>${game.game_name_en}</td>
            <td class="game-url">
                <a href="${game.game_url}" target="_blank" title="${game.game_url}">
                    ${game.game_url}
                </a>
            </td>
            <td><span class="game-version">${game.game_version}</span></td>
            <td><span class="game-status ${statusClass}">${statusText}</span></td>
            <td>${createdAt}</td>
            <td>
                <button class="btn btn-sm btn-primary" onclick="editGame(${game.id})" title="編輯">
                    <i class="fas fa-edit"></i>
                </button>
                <button class="btn btn-sm btn-${game.is_active ? 'warning' : 'success'}" 
                        onclick="toggleGameStatus(${game.id}, ${game.is_active})" 
                        title="${game.is_active ? '停用' : '啟用'}">
                    <i class="fas fa-${game.is_active ? 'ban' : 'check'}"></i>
                </button>
                <button class="btn btn-sm btn-danger" onclick="deleteGame(${game.id})" title="刪除">
                    <i class="fas fa-trash"></i>
                </button>
            </td>
        </tr>
        `;
    });
    
    tbody.innerHTML = html;
}

// 渲染分頁
function renderPagination(pagination) {
    const container = document.getElementById('pagination-container');
    const { page, limit, total, totalPages } = pagination;
    
    let html = `
        <div class="pagination-info">
            <span>顯示第 ${(page - 1) * limit + 1} - ${Math.min(page * limit, total)} 筆，共 ${total} 筆</span>
        </div>
        <div class="pagination-buttons">
    `;
    
    // 上一頁
    html += `<button class="btn btn-sm btn-secondary" ${page === 1 ? 'disabled' : ''} onclick="changePage(${page - 1})">上一頁</button>`;
    
    // 頁碼
    for (let i = 1; i <= totalPages; i++) {
        if (i === 1 || i === totalPages || (i >= page - 2 && i <= page + 2)) {
            html += `<button class="btn btn-sm ${i === page ? 'btn-primary' : 'btn-secondary'}" onclick="changePage(${i})">${i}</button>`;
        } else if (i === page - 3 || i === page + 3) {
            html += `<span>...</span>`;
        }
    }
    
    // 下一頁
    html += `<button class="btn btn-sm btn-secondary" ${page === totalPages ? 'disabled' : ''} onclick="changePage(${page + 1})">下一頁</button>`;
    
    html += '</div>';
    container.innerHTML = html;
}

// 更新統計
function updateStats(games) {
    const total = games.length;
    const active = games.filter(g => g.is_active).length;
    const inactive = games.filter(g => !g.is_active).length;
    
    document.getElementById('total-games').textContent = total;
    document.getElementById('active-games').textContent = active;
    document.getElementById('inactive-games').textContent = inactive;
}

// 切換頁碼
function changePage(page) {
    currentPage = page;
    loadGames();
}

// 顯示通知
function showNotification(message, type = 'success') {
    // 使用現有的通知系統
    alert(message);
}

// 顯示遊戲模態框（新增或編輯）
function showGameModal(gameId = null) {
    const isEdit = gameId !== null;
    const title = isEdit ? '編輯遊戲' : '新增遊戲';

    let modalHtml = `
        <div class="modal show" id="game-modal">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h3 class="modal-title">${title}</h3>
                        <button class="btn-close" onclick="closeModal()"></button>
                    </div>
                    <div class="modal-body">
                        <form id="game-form">
                            <div class="form-group">
                                <label for="game_name_zh">遊戲中文名稱 <span class="required">*</span></label>
                                <input type="text" id="game_name_zh" name="game_name_zh" class="form-control" required>
                            </div>
                            <div class="form-group">
                                <label for="game_name_en">遊戲英文名稱 <span class="required">*</span></label>
                                <input type="text" id="game_name_en" name="game_name_en" class="form-control" required>
                            </div>
                            <div class="form-group">
                                <label for="game_url">遊戲 URL <span class="required">*</span></label>
                                <input type="url" id="game_url" name="game_url" class="form-control" required
                                       placeholder="https://example.com/games/my-game">
                            </div>
                            <div class="form-group">
                                <label for="game_version">遊戲版本</label>
                                <input type="text" id="game_version" name="game_version" class="form-control"
                                       value="1.0.0" placeholder="1.0.0">
                            </div>
                            <div class="form-group">
                                <label for="description">遊戲描述</label>
                                <textarea id="description" name="description" class="form-control" rows="3"
                                          placeholder="簡短描述這個遊戲..."></textarea>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" onclick="closeModal()">取消</button>
                        <button class="btn btn-primary" onclick="saveGame(${gameId})">儲存</button>
                    </div>
                </div>
            </div>
        </div>
    `;

    document.getElementById('modal-container').innerHTML = modalHtml;

    // 添加點擊背景關閉事件
    const modal = document.getElementById('game-modal');
    modal.addEventListener('click', function(event) {
        if (event.target === modal) {
            closeModal();
        }
    });

    // 如果是編輯模式，載入遊戲資料
    if (isEdit) {
        // P1-7: 更新 API 端點
        fetch(`/api/admin/games/${gameId}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const game = data.data;
                    document.getElementById('game_name_zh').value = game.game_name_zh;
                    document.getElementById('game_name_en').value = game.game_name_en;
                    document.getElementById('game_url').value = game.game_url;
                    document.getElementById('game_version').value = game.game_version;
                    document.getElementById('description').value = game.description || '';
                }
            });
    }
}

// 編輯遊戲
function editGame(gameId) {
    showGameModal(gameId);
}

// 儲存遊戲
function saveGame(gameId) {
    const form = document.getElementById('game-form');
    const formData = {
        game_name_zh: document.getElementById('game_name_zh').value,
        game_name_en: document.getElementById('game_name_en').value,
        game_url: document.getElementById('game_url').value,
        game_version: document.getElementById('game_version').value,
        description: document.getElementById('description').value
    };

    // P1-7: 更新 API 端點
    const url = gameId ? `/api/admin/games/${gameId}` : '/api/admin/games';
    const method = gameId ? 'PUT' : 'POST';

    fetch(url, {
        method: method,
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(formData)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showNotification(data.message, 'success');
            closeModal();
            loadGames();
        } else {
            showNotification(data.message || '儲存失敗', 'error');
        }
    })
    .catch(error => {
        console.error('儲存遊戲失敗:', error);
        showNotification('儲存遊戲失敗', 'error');
    });
}

// 切換遊戲狀態
function toggleGameStatus(gameId, currentStatus) {
    const action = currentStatus ? '停用' : '啟用';
    if (!confirm(`確定要${action}此遊戲嗎？`)) {
        return;
    }

    // P1-7: 更新為 PUT 方法更新 is_active 欄位
    fetch(`/api/admin/games/${gameId}`, {
        method: 'PUT',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            is_active: !currentStatus
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showNotification(data.message, 'success');
            loadGames();
        } else {
            showNotification(data.message || '操作失敗', 'error');
        }
    })
    .catch(error => {
        console.error('切換狀態失敗:', error);
        showNotification('切換狀態失敗', 'error');
    });
}

// 刪除遊戲
function deleteGame(gameId) {
    if (!confirm('確定要刪除此遊戲嗎？此操作無法復原。')) {
        return;
    }

    // P1-7: 更新 API 端點
    fetch(`/api/admin/games/${gameId}`, {
        method: 'DELETE'
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showNotification(data.message, 'success');
            loadGames();
        } else {
            showNotification(data.message || '刪除失敗', 'error');
        }
    })
    .catch(error => {
        console.error('刪除遊戲失敗:', error);
        showNotification('刪除遊戲失敗', 'error');
    });
}

// 關閉模態框
function closeModal() {
    document.getElementById('modal-container').innerHTML = '';
}
</script>


