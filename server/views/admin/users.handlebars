{{!-- 用戶管理頁面 --}}

<div class="content-header">
    <h1>用戶管理</h1>
    <p>管理系統用戶、角色權限和訪問控制</p>
</div>

<!-- 操作按鈕 -->
<div class="action-bar">
    <div class="search-box">
        <input type="text" id="search-input" name="search" class="form-control" placeholder="搜尋用戶名稱或電子郵件...">
        <button class="btn btn-primary" type="button" id="search-btn">
            <i class="fas fa-search"></i> 搜尋
        </button>
    </div>
    <div class="action-buttons">
        <button class="btn btn-success" id="new-user-btn">
            <i class="fas fa-user-plus"></i> 新增用戶
        </button>
        <button class="btn btn-info" id="import-users-btn">
            <i class="fas fa-upload"></i> 批量匯入
        </button>
        <button class="btn btn-secondary" id="refresh-btn">
            <i class="fas fa-sync-alt"></i> 重新整理
        </button>
    </div>
</div>

<!-- 篩選器 -->
<div class="filter-bar">
    <div class="filter-group">
        <label for="role-filter">角色篩選：</label>
        <select id="role-filter" name="role-filter" class="form-control">
            <option value="">所有角色</option>
            <option value="super_admin">超級管理員</option>
            <option value="project_manager">專案管理員</option>
            <option value="vendor">廠商用戶</option>
            <option value="project_user">一般用戶</option>
        </select>
    </div>

    <div class="filter-group">
        <label for="status-filter">狀態篩選：</label>
        <select id="status-filter" name="status-filter" class="form-control">
            <option value="">所有狀態</option>
            <option value="active">啟用</option>
            <option value="inactive">停用</option>
            <option value="pending">待啟用</option>
        </select>
    </div>
</div>

<!-- 用戶列表 -->
<div class="data-table-container">
    <div class="table-header">
        <h3>用戶列表</h3>
        <div class="table-stats">
            <span class="stat-item">總用戶：<strong id="total-users">-</strong></span>
            <span class="stat-item">啟用：<strong id="active-users">-</strong></span>
            <span class="stat-item">停用：<strong id="inactive-users">-</strong></span>
        </div>
    </div>

    <div class="table-content">
        <table class="data-table">
            <thead>
                <tr>
                    <th>頭像</th>
                    <th data-sortable="id">User ID</th>
                    <th data-sortable="username">用戶名稱</th>
                    <th data-sortable="full_name">真實姓名</th>
                    <th data-sortable="email">電子郵件</th>
                    <th data-sortable="role">角色</th>
                    <th data-sortable="status">狀態</th>
                    <th data-sortable="last_login">最後登入</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody id="users-table-body">
                <tr>
                    <td colspan="9" class="loading-cell">
                        <div class="loading-spinner"></div>
                        載入用戶數據中...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- 分頁 -->
    <div class="pagination-container" id="pagination-container">
        <div class="pagination-info">
            <span>載入分頁資訊中...</span>
        </div>
    </div>
</div>

<!-- 模態框容器 -->
<div id="modal-container"></div>

<!-- 橋接腳本：傳遞 Handlebars 變數給外部 JavaScript -->
<script>
    window.currentUser = {{{json user}}};
</script>

{{!-- External CSS/JS loaded via additionalCSS and additionalJS in route --}}
