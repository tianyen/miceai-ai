<div class="container-fluid">
    <div class="page-header">
        <h1>遊戲分析</h1>
        <div class="page-actions">
            <button class="btn btn-secondary" onclick="loadData()">
                <i class="fas fa-sync-alt"></i> 重新整理
            </button>
        </div>
    </div>

    <!-- 篩選器 -->
    <div class="filter-section">
        <div class="form-row">
            <div class="form-group col-md-3">
                <label>日期</label>
                <input type="date" class="form-control" id="date-filter">
            </div>
            <div class="form-group col-md-3">
                <label>開始時間</label>
                <input type="datetime-local" class="form-control" id="start-at-filter">
            </div>
            <div class="form-group col-md-3">
                <label>結束時間</label>
                <input type="datetime-local" class="form-control" id="end-at-filter">
            </div>
            <div class="form-group col-md-3">
                <label>專案篩選</label>
                <select class="form-control" id="project-filter">
                    <option value="">全部專案</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-md-3">
                <label>遊戲篩選（排行榜）</label>
                <select class="form-control" id="game-filter">
                    <option value="">全部遊戲</option>
                </select>
            </div>
            <div class="form-group col-md-3">
                <label>每頁筆數</label>
                <select class="form-control" id="page-size-filter">
                    <option value="50" selected>50</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                </select>
            </div>
        </div>
    </div>

    <div class="data-window-banner">
        <div class="data-window-title">資料視窗</div>
        <div class="data-window-primary" id="analytics-window-primary">載入中...</div>
        <div class="data-window-secondary" id="analytics-window-secondary">
            載入中...
        </div>
        <div class="data-window-secondary" id="leaderboard-window-secondary">
            載入中...
        </div>
    </div>

    <!-- 統計卡片 -->
    <div class="stats-cards">
        <div class="stat-card">
            <div class="stat-icon" style="background: #4CAF50;">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-content">
                <div class="stat-label">總用戶數</div>
                <div class="stat-value" id="total-users">0</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: #2196F3;">
                <i class="fas fa-gamepad"></i>
            </div>
            <div class="stat-content">
                <div class="stat-label">遊戲會話</div>
                <div class="stat-value" id="total-sessions">0</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: #FF9800;">
                <i class="fas fa-ticket-alt"></i>
            </div>
            <div class="stat-content">
                <div class="stat-label">兌換券</div>
                <div class="stat-value" id="total-vouchers">0</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: #9C27B0;">
                <i class="fas fa-trophy"></i>
            </div>
            <div class="stat-content">
                <div class="stat-label">最高分數</div>
                <div class="stat-value" id="highest-score">0</div>
            </div>
        </div>
    </div>

    <!-- 玩家行為分析 -->
    <div class="analytics-grid">
        <div class="data-table-container">
            <div class="table-header">
                <h3>📊 唯一玩家 Session 深度</h3>
            </div>
            <div class="table-content">
                <canvas id="session-depth-chart" style="max-height: 320px;"></canvas>
            </div>
        </div>

        <div class="data-table-container">
            <div class="table-header">
                <h3>⏱️ 遊戲時長分佈</h3>
            </div>
            <div class="table-content">
                <canvas id="duration-distribution-chart" style="max-height: 320px;"></canvas>
            </div>
        </div>

        <div class="data-table-container">
            <div class="table-header">
                <h3>🕒 每小時遊玩人數</h3>
            </div>
            <div class="table-content">
                <canvas id="hourly-activity-chart" style="max-height: 320px;"></canvas>
            </div>
        </div>

        <div class="data-table-container">
            <div class="table-header">
                <h3>🔁 留存率觀察</h3>
            </div>
            <div class="table-content">
                <canvas id="retention-chart" style="max-height: 320px;"></canvas>
            </div>
        </div>
    </div>

    <!-- 高分排行榜 -->
    <div class="data-table-container">
        <div class="table-header">
            <h3>🏆 高分排行榜 TOP 10</h3>
        </div>
        <div class="table-content">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 60px;">排名</th>
                        <th>姓名</th>
                        <th>公司</th>
                        <th>遊戲</th>
                        <th>攤位</th>
                        <th style="width: 100px;">最高分數</th>
                        <th style="width: 100px;">遊戲時長</th>
                    </tr>
                </thead>
                <tbody id="leaderboard-container">
                    <tr>
                        <td colspan="7" class="text-center">載入中...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- 用戶列表 -->
    <div class="data-table-container">
        <div class="table-header">
            <h3>👥 用戶列表</h3>
        </div>
        <div class="table-content">
            <div id="users-table-container">
                <div class="text-center">載入中...</div>
            </div>
            <div id="users-pagination" class="pagination-bar"></div>
        </div>
    </div>
</div>

<!-- 用戶軌跡模態框 -->
<div id="journey-modal-container"></div>

