{{!-- 報到管理頁面 --}}

<div class="content-header">
    <h1>報到管理</h1>
    <p>管理活動報到流程和參與者狀態</p>
</div>

<!-- 操作按鈕 -->
<div class="action-bar">
    <div class="search-box">
        <input type="text" id="search-participants" class="form-control" placeholder="搜尋參與者...">
        <button class="btn btn-primary" onclick="searchParticipants()">
            <i class="fas fa-search"></i> 搜尋
        </button>
    </div>
    <div class="action-buttons">
        <button class="btn btn-success" onclick="exportCheckinRecords()">
            <i class="fas fa-download"></i> 匯出報到記錄
        </button>
        <button class="btn btn-success" onclick="openCameraScanner()">
            <i class="fas fa-camera"></i> Webcam 掃描器
        </button>
        <a href="/admin/qr-scanner" class="btn btn-secondary">
            <i class="fas fa-qrcode"></i> 完整掃描頁面
        </a>
        <button class="btn btn-secondary" onclick="refreshParticipants()">
            <i class="fas fa-sync-alt"></i> 重新整理
        </button>
    </div>
</div>

<!-- 統計卡片 -->
<div class="stats-grid" id="stats-grid">
    <div class="loading">載入統計數據...</div>
</div>

<!-- 篩選器 -->
<div class="filter-bar">
    <div class="filter-group">
        <label for="project-select">專案篩選：</label>
        <select id="project-select" class="form-control">
            <option value="">所有專案</option>
            <option value="1">2024年度科技論壇</option>
            <option value="2">春季產品發表會</option>
            <option value="3">客戶感謝晚宴</option>
        </select>
    </div>

    <div class="filter-group">
        <label for="status-filter">報到狀態：</label>
        <select id="status-filter" class="form-control">
            <option value="">所有狀態</option>
            <option value="checked_in">已報到</option>
            <option value="not_checked_in">未報到</option>
            <option value="cancelled">已取消</option>
        </select>
    </div>
</div>

<!-- 參與者列表 -->
<div class="data-table-container">
    <div class="table-header">
        <h3>參與者報到狀態</h3>
        <div class="table-meta">
            <span id="total-count">總計：0 位參與者</span>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>參與者姓名</th>
                    <th>電子郵件</th>
                    <th>電話號碼</th>
                    <th>參與程度</th>
                    <th>報到狀態</th>
                    <th>報到時間</th>
                    <th>QR Code</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody id="participants-table-body">
                <tr>
                    <td colspan="8" class="text-center">
                        <div class="loading">載入參與者數據...</div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- 分頁 -->
    <div class="pagination-container" id="pagination-container">
    </div>
</div>

<!-- 報到詳情模態框容器 -->
<div id="modal-container"></div>

<!-- 匯出結果容器 -->
<div id="export-result"></div>

{{!-- External CSS/JS loaded via additionalCSS and additionalJS in route --}}