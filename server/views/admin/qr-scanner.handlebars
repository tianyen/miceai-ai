<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QR Code 掃描器 - MICE-AI</title>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- External CSS -->
    <link rel="stylesheet" href="/css/admin/pages/qr-scanner.css">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- jsQR 庫 -->
    <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js"></script>

    <!-- CSRF Token Utility -->
    <script src="/js/common/csrf.js"></script>
</head>
<body>
    <div class="scanner-container">
        <div class="page-header">
            <div class="page-title">
                <h1><i class="fas fa-qrcode"></i> QR Code 掃描器</h1>
                <p>掃描參與者 QR Code 進行快速報到</p>
            </div>
            <div class="page-actions">
                <button class="btn btn-secondary" id="toggle-camera-btn">
                    <i class="fas fa-video" id="camera-icon"></i>
                    <span id="camera-text">啟動攝影機</span>
                </button>
                {{#if project_id}}
                <a href="/admin/projects/{{project_id}}/detail" class="btn btn-primary">
                    <i class="fas fa-arrow-left"></i>
                    返回專案
                </a>
                {{else}}
                <a href="/admin/checkin-management" class="btn btn-primary">
                    <i class="fas fa-arrow-left"></i>
                    返回報到管理
                </a>
                {{/if}}
            </div>
        </div>

        <div class="scanner-layout">
            <!-- 攝影機區域 -->
            <div class="camera-section">
                <div class="camera-header">
                    <h3>攝影機預覽</h3>
                    <div class="status-indicator" id="camera-status">
                        <span class="status-dot offline"></span>
                        <span class="status-text">攝影機未啟動</span>
                    </div>
                </div>

                <div class="camera-container">
                    <video id="video" autoplay muted playsinline></video>
                    <div class="scan-overlay">
                        <div class="scan-frame"></div>
                        <div class="scan-line"></div>
                    </div>
                </div>

                <div class="camera-controls">
                    <button class="btn btn-success" id="start-scan" disabled>
                        <i class="fas fa-play"></i>
                        開始掃描
                    </button>
                    <button class="btn btn-warning" id="stop-scan" disabled>
                        <i class="fas fa-stop"></i>
                        停止掃描
                    </button>
                    <button class="btn btn-info" id="switch-camera" disabled>
                        <i class="fas fa-sync-alt"></i>
                        切換攝影機
                    </button>
                </div>

                <div class="scan-result" id="scan-result" style="display: none;">
                    <div class="result-content">
                        <h4>掃描結果</h4>
                        <div class="result-data" id="result-data"></div>
                        <div class="result-actions">
                            <button class="btn btn-primary" id="process-checkin-btn">
                                <i class="fas fa-check"></i>
                                確認報到
                            </button>
                            <button class="btn btn-secondary" id="clear-result-btn">
                                <i class="fas fa-times"></i>
                                清除結果
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 資訊面板 -->
            <div class="info-panel">
                <div class="panel-header">
                    <h3>掃描記錄</h3>
                    <button class="btn btn-sm btn-outline-primary" onclick="refreshScanHistory()">
                        <i class="fas fa-sync-alt"></i>
                        重新整理
                    </button>
                </div>

                <!-- 今日統計 -->
                <div class="today-stats">
                    <div class="loading">載入今日統計...</div>
                </div>

                <!-- 掃描歷史 -->
                <div class="scan-history-container">
                    <h4>最近掃描記錄</h4>
                    <div id="scan-history">
                        <div class="loading">載入掃描記錄...</div>
                    </div>
                </div>

                <!-- 操作說明 -->
                <div class="instructions">
                    <h4>使用說明</h4>
                    <ol>
                        <li>點擊「啟動攝影機」按鈕</li>
                        <li>允許瀏覽器存取攝影機權限</li>
                        <li>點擊「開始掃描」開始掃描</li>
                        <li>將 QR Code 對準攝影機</li>
                        <li>系統會自動識別並處理報到</li>
                    </ol>

                    <div class="tips">
                        <h5>掃描技巧</h5>
                        <ul>
                            <li>確保光線充足</li>
                            <li>保持 QR Code 清晰可見</li>
                            <li>距離攝影機 10-30 公分</li>
                            <li>避免反光和陰影</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- External JavaScript -->
    <script src="/js/admin/pages/qr-scanner.js"></script>
</body>
</html>
