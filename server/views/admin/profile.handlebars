{{!-- 個人資料頁面 --}}

<div class="content-header">
    <h1>個人資料</h1>
    <p>管理個人帳號設定和偏好</p>
</div>

<div class="profile-container">
    <!-- 個人資訊卡片 -->
    <div class="profile-card">
        <div class="profile-header">
            <div class="profile-avatar">
                <div class="avatar-display" id="avatar-display">
                    {{#if user.avatar}}
                    <img src="{{user.avatar}}" alt="{{user.full_name}}">
                    {{else}}
                    <span>{{substring user.full_name 0 1}}</span>
                    {{/if}}
                </div>
                <button class="avatar-upload-btn" onclick="uploadAvatar()">
                    <i class="fas fa-camera"></i>
                </button>
            </div>
            <div class="profile-info">
                <h2>{{user.full_name}}</h2>
                <p class="profile-role">{{user.role}}</p>
                <p class="profile-email">{{user.email}}</p>
            </div>
        </div>
    </div>

    <!-- 設定表單 -->
    <div class="settings-container">
        <!-- 基本資訊 -->
        <div class="settings-section">
            <h3>基本資訊</h3>
            <form id="basic-info-form" class="profile-form">
                <div class="form-row">
                    <div class="form-group">
                        <label for="username">用戶名稱</label>
                        <input type="text" id="username" name="username" class="form-control" value="{{user.username}}"
                            readonly>
                        <small class="form-text">用戶名稱無法修改</small>
                    </div>
                    <div class="form-group">
                        <label for="full_name">真實姓名</label>
                        <input type="text" id="full_name" name="full_name" class="form-control"
                            value="{{user.full_name}}" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="email">電子郵件</label>
                        <input type="email" id="email" name="email" class="form-control" value="{{user.email}}"
                            required>
                    </div>
                    <div class="form-group">
                        <label for="phone">聯絡電話</label>
                        <input type="tel" id="phone" name="phone" class="form-control" value="{{user.phone}}">
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary" id="save-basic-btn">
                        <i class="fas fa-save"></i> 儲存基本資訊
                    </button>
                </div>
            </form>
            <div id="basic-info-messages"></div>
        </div>

        <!-- 密碼修改 -->
        <div class="settings-section">
            <h3>密碼修改</h3>
            <form id="password-form" class="profile-form">
                <div class="form-group">
                    <label for="current_password">目前密碼</label>
                    <input type="password" id="current_password" name="current_password" class="form-control" required>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="new_password">新密碼</label>
                        <input type="password" id="new_password" name="new_password" class="form-control" minlength="8"
                            required>
                        <small class="form-text">密碼至少需要8個字符</small>
                    </div>
                    <div class="form-group">
                        <label for="confirm_password">確認新密碼</label>
                        <input type="password" id="confirm_password" name="confirm_password" class="form-control"
                            required>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-warning" id="save-password-btn">
                        <i class="fas fa-key"></i> 修改密碼
                    </button>
                </div>
            </form>
            <div id="password-messages"></div>
        </div>

        <!-- 偏好設定 -->
        <div class="settings-section">
            <h3>偏好設定</h3>
            <form id="preferences-form" class="profile-form">
                <div class="form-group">
                    <label for="language">語言</label>
                    <select id="language" name="language" class="form-control">
                        <option value="zh-TW">繁體中文</option>
                        <option value="zh-CN">简体中文</option>
                        <option value="en">English</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="timezone">時區</label>
                    <select id="timezone" name="timezone" class="form-control">
                        <option value="Asia/Taipei">台北時間 (UTC+8)</option>
                        <option value="Asia/Shanghai">北京時間 (UTC+8)</option>
                        <option value="UTC">UTC</option>
                    </select>
                </div>

                <div class="form-group">
                    <div class="form-check">
                        <input type="checkbox" id="email_notifications" name="email_notifications"
                            class="form-check-input">
                        <label for="email_notifications" class="form-check-label">
                            接收電子郵件通知
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-check">
                        <input type="checkbox" id="browser_notifications" name="browser_notifications"
                            class="form-check-input">
                        <label for="browser_notifications" class="form-check-label">
                            接收瀏覽器通知
                        </label>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary" id="save-preferences-btn">
                        <i class="fas fa-save"></i> 儲存偏好設定
                    </button>
                </div>
            </form>
            <div id="preferences-messages"></div>
        </div>

        <!-- 登入記錄 -->
        <div class="settings-section">
            <h3>最近登入記錄</h3>
            <div class="login-history" id="login-history">
                <div class="loading-placeholder">
                    <div class="loading-spinner"></div>
                    <span>載入登入記錄...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 訊息容器 -->
<div id="profile-messages"></div>

<!-- 模態框容器 -->
<div id="modal-container"></div>

<style>
    /* 個人資料專用樣式 */
    .profile-container {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 2rem;
    }

    .profile-card {
        background: white;
        border-radius: var(--border-radius-lg);
        box-shadow: var(--shadow);
        padding: 2rem;
        height: fit-content;
    }

    .profile-header {
        text-align: center;
    }

    .profile-avatar {
        position: relative;
        display: inline-block;
        margin-bottom: 1rem;
    }

    .avatar-display {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background-color: var(--primary-color);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        font-weight: 600;
        overflow: hidden;
    }

    .avatar-display img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .avatar-upload-btn {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background-color: var(--primary-color);
        color: white;
        border: 3px solid white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background-color var(--transition-fast);
    }

    .avatar-upload-btn:hover {
        background-color: #2980b9;
    }

    .profile-info h2 {
        margin: 0 0 0.5rem 0;
        color: var(--gray-900);
    }

    .profile-role {
        color: var(--primary-color);
        font-weight: 500;
        margin: 0 0 0.25rem 0;
    }

    .profile-email {
        color: var(--gray-600);
        margin: 0;
    }

    .settings-container {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .settings-section {
        background: white;
        border-radius: var(--border-radius-lg);
        box-shadow: var(--shadow);
        padding: 2rem;
    }

    .settings-section h3 {
        margin: 0 0 1.5rem 0;
        color: var(--gray-900);
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 0.5rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 500;
        color: var(--gray-700);
    }

    .form-text {
        font-size: 0.85rem;
        color: var(--gray-500);
        margin-top: 0.25rem;
    }

    .form-check {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-check-input {
        margin: 0;
    }

    .form-actions {
        margin-top: 1.5rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border-color);
    }

    .login-history {
        min-height: 200px;
    }

    .login-history-list {
        max-height: 300px;
        overflow-y: auto;
    }

    .login-record {
        border-bottom: 1px solid var(--border-color);
        padding: 1rem 0;
    }

    .login-record:last-child {
        border-bottom: none;
    }

    .login-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .login-time {
        font-weight: 500;
        color: var(--gray-900);
    }

    .login-details {
        display: flex;
        gap: 1rem;
        font-size: 0.875rem;
    }

    .login-ip {
        color: var(--gray-600);
    }

    @media (max-width: 768px) {
        .profile-container {
            grid-template-columns: 1fr;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .avatar-display {
            width: 80px;
            height: 80px;
            font-size: 2rem;
        }

        .avatar-upload-btn {
            width: 28px;
            height: 28px;
        }
    }
</style>

<script>
    // 個人資料專用 JavaScript
    $(document).ready(function () {
        // 載入登入記錄
        loadLoginHistory();

        // 載入用戶偏好設定
        loadUserPreferences();

        // 基本資訊表單提交
        $('#basic-info-form').on('submit', function (e) {
            e.preventDefault();
            saveBasicInfo();
        });

        // 密碼修改表單提交
        $('#password-form').on('submit', function (e) {
            e.preventDefault();
            changePassword();
        });

        // 偏好設定表單提交
        $('#preferences-form').on('submit', function (e) {
            e.preventDefault();
            savePreferences();
        });

        // 密碼確認驗證
        $('#confirm_password').on('input', function () {
            const newPassword = $('#new_password').val();
            const confirmPassword = $(this).val();

            if (confirmPassword && confirmPassword !== newPassword) {
                this.setCustomValidity('密碼不一致');
            } else {
                this.setCustomValidity('');
            }
        });
    });

    // 載入登入記錄函數
    function loadLoginHistory() {
        $.ajax({
            url: '/api/admin/profile/login-history',
            method: 'GET',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            },
            success: function (response) {
                if (response.success) {
                    $('#login-history').html(response.data);
                } else {
                    $('#login-history').html('<div class="text-danger">載入登入記錄失敗</div>');
                }
            },
            error: function () {
                $('#login-history').html('<div class="text-danger">載入登入記錄失敗</div>');
            }
        });
    }

    // 載入用戶偏好設定
    function loadUserPreferences() {
        $.ajax({
            url: '/api/admin/profile/preferences',
            method: 'GET',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            },
            success: function (response) {
                if (response.success && response.data) {
                    const prefs = response.data;
                    $('#language').val(prefs.language || 'zh-TW');
                    $('#timezone').val(prefs.timezone || 'Asia/Taipei');
                    $('#email_notifications').prop('checked', prefs.email_notifications || false);
                    $('#browser_notifications').prop('checked', prefs.browser_notifications || false);
                } else {
                    // 設置默認值
                    $('#language').val('zh-TW');
                    $('#timezone').val('Asia/Taipei');
                    $('#email_notifications').prop('checked', false);
                    $('#browser_notifications').prop('checked', false);
                }
            },
            error: function () {
                // 設置默認值
                $('#language').val('zh-TW');
                $('#timezone').val('Asia/Taipei');
                $('#email_notifications').prop('checked', false);
                $('#browser_notifications').prop('checked', false);
            }
        });
    }

    // 儲存基本資訊
    function saveBasicInfo() {
        const $form = $('#basic-info-form');
        const $btn = $('#save-basic-btn');
        const $messages = $('#basic-info-messages');

        // 收集表單數據
        const formData = {
            full_name: $('#full_name').val(),
            email: $('#email').val(),
            phone: $('#phone').val()
        };

        console.log('🔍 Sending basic info data:', formData);

        // 禁用按鈕
        $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> 儲存中...');

        $.ajax({
            url: '/api/admin/profile/basic',
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            data: JSON.stringify(formData),
            success: function (response) {
                if (response.success) {
                    $messages.html('<div class="alert alert-success">' + response.message + '</div>');
                    if (typeof showNotification === 'function') {
                        showNotification(response.message, 'success');
                    }
                } else {
                    $messages.html('<div class="alert alert-danger">' + response.message + '</div>');
                }
            },
            error: function (xhr) {
                let errorMessage = '更新基本資訊失敗';
                if (xhr.responseJSON && xhr.responseJSON.message) {
                    errorMessage = xhr.responseJSON.message;
                }
                $messages.html('<div class="alert alert-danger">' + errorMessage + '</div>');
                if (typeof showNotification === 'function') {
                    showNotification(errorMessage, 'error');
                }
            },
            complete: function () {
                // 恢復按鈕
                $btn.prop('disabled', false).html('<i class="fas fa-save"></i> 儲存基本資訊');
            }
        });
    }

    // 修改密碼
    function changePassword() {
        const $form = $('#password-form');
        const $btn = $('#save-password-btn');
        const $messages = $('#password-messages');

        // 收集表單數據
        const formData = {
            current_password: $('#current_password').val(),
            new_password: $('#new_password').val(),
            confirm_password: $('#confirm_password').val()
        };

        // 驗證密碼
        if (formData.new_password !== formData.confirm_password) {
            $messages.html('<div class="alert alert-danger">新密碼與確認密碼不一致</div>');
            return;
        }

        if (formData.new_password.length < 8) {
            $messages.html('<div class="alert alert-danger">密碼至少需要8個字符</div>');
            return;
        }

        console.log('🔍 Sending password change data');

        // 禁用按鈕
        $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> 修改中...');

        $.ajax({
            url: '/api/admin/profile/password',
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            data: JSON.stringify(formData),
            success: function (response) {
                if (response.success) {
                    $messages.html('<div class="alert alert-success">' + response.message + '</div>');
                    $form[0].reset(); // 清空表單
                    if (typeof showNotification === 'function') {
                        showNotification(response.message, 'success');
                    }
                } else {
                    $messages.html('<div class="alert alert-danger">' + response.message + '</div>');
                }
            },
            error: function (xhr) {
                let errorMessage = '修改密碼失敗';
                if (xhr.responseJSON && xhr.responseJSON.message) {
                    errorMessage = xhr.responseJSON.message;
                }
                $messages.html('<div class="alert alert-danger">' + errorMessage + '</div>');
                if (typeof showNotification === 'function') {
                    showNotification(errorMessage, 'error');
                }
            },
            complete: function () {
                // 恢復按鈕
                $btn.prop('disabled', false).html('<i class="fas fa-key"></i> 修改密碼');
            }
        });
    }

    // 儲存偏好設定
    function savePreferences() {
        const $form = $('#preferences-form');
        const $btn = $('#save-preferences-btn');
        const $messages = $('#preferences-messages');

        // 收集表單數據
        const formData = {
            language: $('#language').val(),
            timezone: $('#timezone').val(),
            email_notifications: $('#email_notifications').is(':checked'),
            browser_notifications: $('#browser_notifications').is(':checked')
        };

        console.log('🔍 Sending preferences data:', formData);

        // 禁用按鈕
        $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> 儲存中...');

        $.ajax({
            url: '/api/admin/profile/preferences',
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            data: JSON.stringify(formData),
            success: function (response) {
                if (response.success) {
                    $messages.html('<div class="alert alert-success">' + response.message + '</div>');
                    if (typeof showNotification === 'function') {
                        showNotification(response.message, 'success');
                    }
                } else {
                    $messages.html('<div class="alert alert-danger">' + response.message + '</div>');
                }
            },
            error: function (xhr) {
                let errorMessage = '儲存偏好設定失敗';
                if (xhr.responseJSON && xhr.responseJSON.message) {
                    errorMessage = xhr.responseJSON.message;
                }
                $messages.html('<div class="alert alert-danger">' + errorMessage + '</div>');
                if (typeof showNotification === 'function') {
                    showNotification(errorMessage, 'error');
                }
            },
            complete: function () {
                // 恢復按鈕
                $btn.prop('disabled', false).html('<i class="fas fa-save"></i> 儲存偏好設定');
            }
        });
    }

    // 上傳頭像功能
    function uploadAvatar() {
        $.ajax({
            url: '/admin/profile/avatar/upload',
            method: 'GET',
            success: function (html) {
                $('#modal-container').html(html);
                const modal = $('#modal-container .modal')[0];
                if (modal) {
                    $(modal).addClass('show');
                    $('body').addClass('modal-open');
                }
            },
            error: function (xhr) {
                console.error('載入頭像上傳表單失敗:', xhr);
                if (typeof showNotification === 'function') {
                    showNotification('載入頭像上傳表單失敗', 'error');
                } else {
                    alert('載入頭像上傳表單失敗');
                }
            }
        });
    }
</script>