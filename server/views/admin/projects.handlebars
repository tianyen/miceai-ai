{{!-- MICE-AI 項目管理頁面 --}}

<div class="content-header">
    <h1>專案管理</h1>
    <p>管理活動專案、報到狀況和參加者資料</p>
</div>

<!-- 操作按鈕 -->
<div class="action-bar">
    <div class="search-box">
        <input type="text" id="search-input" class="form-control" placeholder="搜尋專案名稱或代碼...">
        <button class="btn btn-primary" onclick="searchProjects()">
            <i class="fas fa-search"></i> 搜尋
        </button>
    </div>
    <div class="action-buttons">
        <button class="btn btn-success" onclick="openNewProjectModal()">
            <i class="fas fa-plus"></i> 新增專案
        </button>
        <button class="btn btn-secondary" onclick="refreshProjects()">
            <i class="fas fa-sync-alt"></i> 重新整理
        </button>
    </div>
</div>

<!-- 專案列表 -->
<div class="data-table-container">
    <div class="table-header">
        <h3>專案列表</h3>
        <div class="table-controls">
            <select id="status-filter" class="form-control" onchange="searchProjects()">
                <option value="">所有狀態</option>
                <option value="active">進行中</option>
                <option value="completed">已完成</option>
                <option value="cancelled">已取消</option>
            </select>
        </div>
    </div>

    <div class="table-content">
        <table class="data-table">
            <thead>
                <tr>
                    <th data-sortable="id">Project ID</th>
                    <th data-sortable="name">專案名稱</th>
                    <th data-sortable="code">專案代碼</th>
                    <th data-sortable="event_date">活動日期</th>
                    <th data-sortable="status">狀態</th>
                    <th data-sortable="participant_count">參加者數量</th>
                    <th data-sortable="created_at">創建時間</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody id="projects-table-body">
                <tr>
                    <td colspan="8" class="loading-cell">
                        <div class="loading-spinner"></div>
                        載入專案數據中...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- 分頁 -->
    <div class="pagination-container" id="pagination-container">
        <div class="pagination-info">
            <span>載入分頁資訊中...</span>
        </div>
    </div>
</div>

<!-- 模態框容器 -->
<div id="modal-container"></div>
