        .sub-tab-btn {
            padding: 0.75rem 1.25rem;
            border: none;
            background: transparent;
            color: #6c757d;
            font-weight: 500;
            cursor: pointer;
            border-bottom: 2px solid transparent;
            margin-bottom: -2px;
            transition: all 0.2s;
        }

        .sub-tab-btn:hover {
            color: #495057;
            background: #f8f9fa;
        }

        .sub-tab-btn.active {
            color: #007bff;
            border-bottom-color: #007bff;
        }

        .sub-tab-content {
            display: none;
        }

        .sub-tab-content.active {
            display: block;
        }

        .subtab-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .subtab-header h4 {
            margin: 0;
