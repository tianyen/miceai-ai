{{!-- 專案詳情頁面 --}}

<div class="content-header">
    <h1>{{project.project_name}}</h1>
    <p>
        <span class="badge badge-secondary">#{{project.id}}</span>
        專案代碼：{{project.project_code}} | 建立者：{{project.creator_name}}
    </p>
</div>

<!-- 專案資訊卡片 -->
<div class="project-overview">
    <div class="overview-grid">
        <div class="info-card">
            <div class="card-header">
                <h3>專案資訊</h3>
            </div>
            <div class="card-content">
                <div class="info-item">
                    <label>Project ID：</label>
                    <span class="badge badge-secondary">#{{project.id}}</span>
                </div>
                <div class="info-item">
                    <label>專案名稱：</label>
                    <span>{{project.project_name}}</span>
                </div>
                <div class="info-item">
                    <label>專案代碼：</label>
                    <span>{{project.project_code}}</span>
                </div>
                <div class="info-item">
                    <label>活動日期：</label>
                    <span>{{#if project.event_date}}{{formatDate project.event_date}}{{else}}-{{/if}}</span>
                </div>
                <div class="info-item">
                    <label>活動地點：</label>
                    <span>{{#if project.event_location}}{{project.event_location}}{{else}}-{{/if}}</span>
                </div>
                <div class="info-item">
                    <label>專案狀態：</label>
                    <span class="status-{{project.status}}">
                        {{#eq project.status 'active'}}進行中{{/eq}}
                        {{#eq project.status 'completed'}}已完成{{/eq}}
                        {{#eq project.status 'cancelled'}}已取消{{/eq}}
                        {{#eq project.status 'draft'}}草稿{{/eq}}
                    </span>
                </div>
                <div class="info-item">
                    <label>關聯模板：</label>
                    <span>
                        {{#if project.template_name}}
                            <a href="/admin/templates/{{project.template_id}}/preview" class="template-link" target="_blank">
                                <i class="fas fa-file-alt"></i> {{project.template_name}}
                            </a>
                        {{else}}
                            <span class="text-muted">未設定模板</span>
                        {{/if}}
                    </span>
                </div>
            </div>
        </div>

        <div class="stats-card">
            <div class="card-header">
                <h3>專案統計</h3>
                <button class="btn btn-sm btn-secondary" onclick="refreshStats()">
                    <i class="fas fa-sync-alt"></i>
                </button>
            </div>
            <div class="card-content" id="project-stats">
                <div class="loading">載入統計中...</div>
            </div>
        </div>
    </div>
</div>

<!-- 功能選項卡 -->
<div class="project-tabs">
    <nav class="tab-nav">
        <button class="tab-btn active" data-tab="participants">參加者管理</button>
        <button class="tab-btn" data-tab="form-settings">報名設定</button>
        <button class="tab-btn" data-tab="questionnaires">問卷狀況</button>
        <button class="tab-btn" data-tab="checkin">簽到管理</button>
        <button class="tab-btn" data-tab="tracking">參加者追蹤</button>
        <button class="tab-btn" data-tab="business-cards">QR Code 名片</button>
        <button class="tab-btn" data-tab="qr-scanner">QR掃描</button>
        <button class="tab-btn" data-tab="booths">攤位設定</button>
        <button class="tab-btn" data-tab="games">遊戲設定</button>
        {{#if (eq project.project_code 'INFOMONTH2025')}}
        <button class="tab-btn" data-tab="wish-tree">🌳 許願樹</button>
        {{/if}}
    </nav>

    <!-- 參加者管理 -->
    <div class="tab-content active" id="participants-tab">
        <div class="section-header">
            <h3>參加者管理</h3>
            <div class="section-actions">
                <button class="btn btn-success" onclick="exportParticipants()">
                    <i class="fas fa-download"></i> 匯出參加者
                </button>
                <button class="btn btn-secondary" onclick="refreshParticipants()">
                    <i class="fas fa-sync-alt"></i> 重新整理
                </button>
            </div>
        </div>

        <div class="search-bar" style="margin-bottom: 1rem;">
            <div class="input-group" style="max-width: 400px;">
                <input type="text" id="participants-search" class="form-control" placeholder="搜尋姓名或 Email...">
                <div class="input-group-append">
                    <button class="btn btn-primary" onclick="searchParticipants()">
                        <i class="fas fa-search"></i>
                    </button>
                    <button class="btn btn-secondary" onclick="clearParticipantsSearch()">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="data-table-container">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>姓名</th>
                            <th>電子郵件</th>
                            <th>電話</th>
                            <th>小孩</th>
                            <th>參與程度</th>
                            <th>報到狀態</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody id="participants-list">
                        <tr>
                            <td colspan="8" class="text-center">
                                <div class="loading">載入參加者資料中...</div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div id="participants-pagination"></div>
        </div>
    </div>

    <!-- 報名設定 -->
    <div class="tab-content" id="form-settings-tab">
        <div class="section-header">
            <h3>報名表單設定</h3>
            <div class="section-actions">
                <button class="btn btn-success" onclick="saveFormConfig()">
                    <i class="fas fa-save"></i> 儲存設定
                </button>
            </div>
        </div>

        <div class="form-settings-container">
            <div class="settings-group">
                <h4>必填欄位</h4>
                <div class="field-options">
                    <label class="field-checkbox">
                        <input type="checkbox" name="required_name" checked disabled> 姓名 <span class="badge">固定必填</span>
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" name="required_email" checked disabled> 電子郵件 <span class="badge">固定必填</span>
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" name="required_phone" checked disabled> 手機號碼 <span class="badge">固定必填</span>
                    </label>
                </div>
            </div>

            <div class="settings-group">
                <h4>選填欄位</h4>
                <div class="field-options">
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_company" name="optional_company" checked> 公司名稱
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_position" name="optional_position" checked> 職位
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_gender" name="optional_gender" checked> 性別
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_title" name="optional_title" checked> 尊稱
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_notes" name="optional_notes" checked> 留言備註
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_adult_age" name="optional_adult_age"> 成人年齡
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_children_count" name="optional_children_count"> 小孩人數（自動計算）
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_children_ages" name="optional_children_ages"> 小孩年齡區間（0-6/6-12/12-18歲）
                    </label>
                </div>
            </div>

            <div class="settings-group">
                <h4>性別選項</h4>
                <input type="text" id="gender_options" class="form-control" value="男, 女, 其他" placeholder="以逗號分隔">
            </div>

            <div class="settings-group">
                <h4>尊稱選項</h4>
                <input type="text" id="title_options" class="form-control" value="先生, 女士, 博士, 教授" placeholder="以逗號分隔">
            </div>
        </div>
    </div>

    <!-- 問卷狀況 -->
    <div class="tab-content" id="questionnaires-tab">
        <div class="section-header">
            <h3>問卷填寫狀況</h3>
            <div class="section-actions">
                <button class="btn btn-primary" onclick="createQuestionnaire()">
                    <i class="fas fa-plus"></i> 新建問卷
                </button>
            </div>
        </div>

        <div id="questionnaires-content">
            <div class="loading">載入問卷資料中...</div>
        </div>
    </div>

    <!-- 簽到管理 -->
    <div class="tab-content" id="checkin-tab">
        <div class="section-header">
            <h3>簽到管理</h3>
            <div class="section-actions">
                <button class="btn btn-success" onclick="openQRScanner()" id="qr-scan-btn">
                    <i class="fas fa-qrcode"></i> 掃描 QR Code
                </button>
                <button class="btn btn-warning" onclick="bulkCheckin()">
                    <i class="fas fa-users"></i> 批量簽到
                </button>
            </div>
        </div>

        <div class="checkin-stats" id="checkin-stats">
            <div class="loading">載入簽到統計中...</div>
        </div>

        <div class="checkin-list" id="checkin-list">
            <div class="loading">載入簽到記錄中...</div>
        </div>
    </div>

    <!-- 參加者追蹤 -->
    <div class="tab-content" id="tracking-tab">
        <div class="section-header">
            <h3>參加者追蹤</h3>
            <div class="search-box">
                <input type="text" id="tracking-search" placeholder="輸入參加者姓名或 Trace ID">
                <button class="btn btn-primary" onclick="searchTracking()">
                    <i class="fas fa-search"></i> 搜尋
                </button>
            </div>
        </div>

        <div id="tracking-results">
            <div class="tracking-placeholder">
                <i class="fas fa-search"></i>
                <p>請搜尋參加者以查看追蹤資訊</p>
            </div>
        </div>
    </div>

    <!-- QR Code 名片 -->
    <div class="tab-content" id="business-cards-tab">
        <div class="section-header">
            <h3>QR Code 名片管理</h3>
            <div class="section-actions">
                <button class="btn btn-success" onclick="exportBusinessCards()">
                    <i class="fas fa-download"></i> 匯出名片
                </button>
                <button class="btn btn-secondary" onclick="refreshBusinessCards()">
                    <i class="fas fa-sync-alt"></i> 重新整理
                </button>
            </div>
        </div>

        <!-- 搜尋和篩選 -->
        <div class="filter-section">
            <div class="search-box">
                <input type="text" id="business-card-search" placeholder="搜尋姓名、公司或電子郵件..." class="form-control">
                <button class="btn btn-primary" onclick="searchBusinessCards()">
                    <i class="fas fa-search"></i> 搜尋
                </button>
            </div>
        </div>

        <!-- 名片列表 -->
        <div class="business-cards-container">
            <div class="table-responsive">
                <table class="table table-striped" id="business-cards-table">
                    <thead>
                        <tr>
                            <th>姓名</th>
                            <th>職稱</th>
                            <th>公司</th>
                            <th>聯絡方式</th>
                            <th>掃描次數</th>
                            <th>建立時間</th>
                            <th>狀態</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody id="business-cards-tbody">
                        <!-- 動態載入名片資料 -->
                    </tbody>
                </table>
            </div>

            <!-- 分頁 -->
            <div class="pagination-container" id="business-cards-pagination">
                <!-- 動態載入分頁 -->
            </div>
        </div>

        <!-- 載入中指示器 -->
        <div class="loading-indicator" id="business-cards-loading" style="display: none;">
            <div class="spinner"></div>
            <p>載入中...</p>
        </div>
    </div>

    <!-- QR掃描 -->
    <div class="tab-content" id="qr-scanner-tab">
        <div class="section-header">
            <h3>QR Code 掃描器</h3>
            <div class="section-actions">
                <button class="btn btn-primary" onclick="openScannerWindow()">
                    <i class="fas fa-external-link-alt"></i> 開啟掃描視窗
                </button>
            </div>
        </div>

        <div class="scanner-info">
            <div class="info-box">
                <h4>掃描說明</h4>
                <ul>
                    <li>點擊「開啟掃描視窗」開始掃描</li>
                    <li>將參加者的 QR Code 對準攝影機</li>
                    <li>系統會自動識別並處理簽到</li>
                    <li>掃描結果會即時更新到簽到記錄中</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- 攤位設定 -->
    <div class="tab-content" id="booths-tab">
        <div class="section-header">
            <h3>攤位設定</h3>
            <div class="section-actions">
                <button class="btn btn-success" onclick="addBoothModal()">
                    <i class="fas fa-plus"></i> 新增攤位
                </button>
                <button class="btn btn-secondary" onclick="refreshBooths()">
                    <i class="fas fa-sync-alt"></i> 重新整理
                </button>
            </div>
        </div>

        <div class="data-table-container">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>攤位名稱</th>
                            <th>代碼</th>
                            <th>位置</th>
                            <th>狀態</th>
                            <th>綁定遊戲</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody id="project-booths-table">
                        <tr>
                            <td colspan="7" class="text-center">
                                <div class="spinner"></div>
                                <p>載入中...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- 遊戲設定 -->
    <div class="tab-content" id="games-tab">
        <div class="section-header">
            <h3>遊戲設定</h3>
            <div class="section-actions">
                <button class="btn btn-success" onclick="bindGameModal()">
                    <i class="fas fa-plus"></i> 綁定遊戲
                </button>
                <button class="btn btn-secondary" onclick="refreshProjectGames()">
                    <i class="fas fa-sync-alt"></i> 重新整理
                </button>
            </div>
        </div>

        <div class="data-table-container">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>遊戲名稱</th>
                            <th>狀態</th>
                            <th>關聯兌換券</th>
                            <th>庫存</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody id="project-games-table">
                        <tr>
                            <td colspan="7" class="text-center">
                                <div class="spinner"></div>
                                <p>載入中...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {{#if (eq project.project_code 'INFOMONTH2025')}}
    <!-- 許願樹 Tab -->
    <div class="tab-content" id="wish-tree-tab">
        <div class="section-header">
            <h3>🌳 許願樹統計</h3>
            <div class="section-actions">
                <a href="/admin/wish-tree/list?project_id={{project.id}}" class="btn btn-primary" target="_blank">
                    <i class="fas fa-list"></i> 查看所有許願
                </a>
                <a href="/admin/wish-tree/stats?project_id={{project.id}}" class="btn btn-success" target="_blank">
                    <i class="fas fa-chart-bar"></i> 詳細統計
                </a>
            </div>
        </div>

        <!-- 統計卡片 -->
        <div class="stats-grid-inline" style="margin-bottom: 2rem;">
            <div class="stat-card-inline primary">
                <div class="stat-value" id="wish-total">-</div>
                <div class="stat-label">總許願數</div>
            </div>
            <div class="stat-card-inline success">
                <div class="stat-value" id="wish-today">-</div>
                <div class="stat-label">今日許願</div>
            </div>
            <div class="stat-card-inline warning">
                <div class="stat-value" id="wish-peak-hour">-</div>
                <div class="stat-label">最高峰時段</div>
            </div>
            <div class="stat-card-inline info">
                <div class="stat-value" id="wish-avg">-</div>
                <div class="stat-label">平均每小時</div>
            </div>
        </div>

        <!-- 最近許願列表 -->
        <div class="data-table-container">
            <h4 style="margin-bottom: 1rem;">最近許願記錄</h4>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th>許願內容</th>
                            <th style="width: 180px;">時間</th>
                            <th style="width: 150px;">IP 地址</th>
                        </tr>
                    </thead>
                    <tbody id="wish-tree-table">
                        <tr>
                            <td colspan="4" class="text-center">
                                <div class="spinner"></div>
                                <p>載入中...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {{/if}}
</div>

<!-- 模態框容器 -->
<div id="modal-container"></div>

{{!-- Bridge script: 傳遞 Handlebars 變數給外部 JS --}}
<script>window.projectId = {{project.id}};</script>
