{{!-- 專案詳情頁面 --}}

<div class="content-header">
    <h1>{{project.project_name}}</h1>
    <p>
        <span class="badge badge-secondary">#{{project.id}}</span>
        專案代碼：{{project.project_code}} | 建立者：{{project.creator_name}}
    </p>
</div>

<!-- 專案資訊卡片 -->
<div class="project-overview">
    <div class="overview-grid">
        <div class="info-card">
            <div class="card-header">
                <h3>專案資訊</h3>
            </div>
            <div class="card-content">
                <div class="info-item">
                    <label>Project ID：</label>
                    <span class="badge badge-secondary">#{{project.id}}</span>
                </div>
                <div class="info-item">
                    <label>專案名稱：</label>
                    <span>{{project.project_name}}</span>
                </div>
                <div class="info-item">
                    <label>專案代碼：</label>
                    <span>{{project.project_code}}</span>
                </div>
                <div class="info-item">
                    <label>活動日期：</label>
                    <span>{{#if project.event_date}}{{formatDate project.event_date}}{{else}}-{{/if}}</span>
                </div>
                <div class="info-item">
                    <label>活動地點：</label>
                    <span>{{#if project.event_location}}{{project.event_location}}{{else}}-{{/if}}</span>
                </div>
                <div class="info-item">
                    <label>專案狀態：</label>
                    <span class="status-{{project.status}}">
                        {{#eq project.status 'active'}}進行中{{/eq}}
                        {{#eq project.status 'completed'}}已完成{{/eq}}
                        {{#eq project.status 'cancelled'}}已取消{{/eq}}
                        {{#eq project.status 'draft'}}草稿{{/eq}}
                    </span>
                </div>
                <div class="info-item">
                    <label>關聯模板：</label>
                    <span>
                        {{#if project.template_name}}
                            <a href="/admin/templates/{{project.template_id}}/preview" class="template-link" target="_blank">
                                <i class="fas fa-file-alt"></i> {{project.template_name}}
                            </a>
                        {{else}}
                            <span class="text-muted">未設定模板</span>
                        {{/if}}
                    </span>
                </div>
                <div class="info-item" style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #eee;">
                    <button class="btn btn-success" onclick="openScannerWindow()" style="width: 100%;">
                        <i class="fas fa-qrcode"></i> QR Code 掃描報到
                    </button>
                </div>
            </div>
        </div>

        <div class="stats-card">
            <div class="card-header">
                <h3>專案統計</h3>
                <button class="btn btn-sm btn-secondary" onclick="refreshStats()">
                    <i class="fas fa-sync-alt"></i>
                </button>
            </div>
            <div class="card-content" id="project-stats">
                <div class="loading">載入統計中...</div>
            </div>
        </div>
    </div>
</div>

<!-- 功能選項卡 -->
<div class="project-tabs">
    <nav class="tab-nav">
        <button class="tab-btn active" data-tab="participants">參加者管理</button>
        <button class="tab-btn" data-tab="email-management">📧 郵件管理</button>
        <button class="tab-btn" data-tab="form-settings">報名設定</button>
        <button class="tab-btn" data-tab="checkin">簽到管理</button>
        <button class="tab-btn" data-tab="tracking">參加者追蹤</button>
        {{#if features.questionnaires}}
        <button class="tab-btn" data-tab="questionnaires">問卷狀況</button>
        {{/if}}
        {{#if features.businessCards}}
        <button class="tab-btn" data-tab="business-cards">QR Code 名片</button>
        {{/if}}
        {{#if features.booths}}
        <button class="tab-btn" data-tab="booths">攤位設定</button>
        {{/if}}
        {{#if features.games}}
        <button class="tab-btn" data-tab="games">遊戲設定</button>
        {{/if}}
        {{#if (eq project.project_code 'INFOMONTH2025')}}
        <button class="tab-btn" data-tab="wish-tree">🌳 許願樹</button>
        {{/if}}
    </nav>

    <!-- 參加者管理 -->
    <div class="tab-content active" id="participants-tab">
        <div class="section-header">
            <h3>參加者管理</h3>
        </div>

        <!-- 操作列：與 checkin-management 一致 -->
        <div class="action-bar">
            <div class="search-box">
                <input type="text" id="participants-search" class="form-control" placeholder="搜尋姓名、Email 或電話...">
                <button class="btn btn-primary" onclick="searchParticipants()">
                    <i class="fas fa-search"></i> 搜尋
                </button>
                <button class="btn btn-secondary" onclick="clearParticipantsSearch()">
                    <i class="fas fa-times"></i> 清除
                </button>
            </div>
            <div class="action-buttons">
                <button class="btn btn-warning" onclick="checkDuplicates()">
                    <i class="fas fa-copy"></i> 檢測重複
                </button>
                <button class="btn btn-primary" onclick="addParticipant()">
                    <i class="fas fa-plus"></i> 新增
                </button>
                <button class="btn btn-success" onclick="exportParticipants()">
                    <i class="fas fa-download"></i> 匯出
                </button>
                <button class="btn btn-secondary" onclick="refreshParticipants()">
                    <i class="fas fa-sync-alt"></i>
                </button>
            </div>
        </div>

        <div class="data-table-container">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th class="sortable" onclick="sortParticipants('id')" data-sort="id">
                                ID <i class="fas fa-sort sort-icon" id="sort-icon-id"></i>
                            </th>
                            <th>姓名</th>
                            <th>電子郵件</th>
                            <th>電話</th>
                            <th>小孩</th>
                            <th class="sortable" onclick="sortParticipants('created_at')" data-sort="created_at">
                                報名時間 <i class="fas fa-sort sort-icon" id="sort-icon-created_at"></i>
                            </th>
                            <th class="sortable" onclick="sortParticipants('checked_in_at')" data-sort="checked_in_at">
                                報到時間 <i class="fas fa-sort sort-icon" id="sort-icon-checked_in_at"></i>
                            </th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody id="participants-list">
                        <tr>
                            <td colspan="8" class="text-center">
                                <div class="loading">載入參加者資料中...</div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div id="participants-pagination"></div>
        </div>
    </div>

    <!-- 報名設定 -->
    <div class="tab-content" id="form-settings-tab">
        <div class="section-header">
            <h3>報名表單設定</h3>
            <div class="section-actions">
                <button class="btn btn-success" onclick="saveFormConfig()">
                    <i class="fas fa-save"></i> 儲存設定
                </button>
            </div>
        </div>

        <div class="form-settings-container">
            <div class="settings-group">
                <h4>必填欄位</h4>
                <div class="field-options">
                    <label class="field-checkbox">
                        <input type="checkbox" name="required_name" checked disabled> 姓名 <span class="badge">固定必填</span>
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" name="required_email" checked disabled> 電子郵件 <span class="badge">固定必填</span>
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" name="required_phone" checked disabled> 手機號碼 <span class="badge">固定必填</span>
                    </label>
                </div>
            </div>

            <div class="settings-group">
                <h4>選填欄位</h4>
                <div class="field-options">
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_company" name="optional_company" checked> 公司名稱
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_position" name="optional_position" checked> 職位
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_gender" name="optional_gender" checked> 性別
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_title" name="optional_title" checked> 尊稱
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_notes" name="optional_notes" checked> 留言備註
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_adult_age" name="optional_adult_age"> 成人年齡
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_children_count" name="optional_children_count"> 小孩人數（自動計算）
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="field_children_ages" name="optional_children_ages"> 小孩年齡區間（0-6/6-12/12-18歲）
                    </label>
                </div>
            </div>

            <div class="settings-group">
                <h4>前端資訊區塊開關（Feature Toggles）</h4>
                <div class="field-options">
                    <label class="field-checkbox">
                        <input type="checkbox" id="toggle_show_event_info" checked> 顯示活動資訊（預設開啟）
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="toggle_show_booth_info"> 顯示攤位資訊
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="toggle_show_voucher_info"> 顯示兌換券資訊
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="toggle_show_vendor_info"> 顯示券商/活動商資訊
                    </label>
                    <label class="field-checkbox">
                        <input type="checkbox" id="toggle_show_inventory_info"> 顯示庫存資訊（total/remaining）
                    </label>
                </div>
            </div>

            <div class="settings-group">
                <h4>性別選項</h4>
                <input type="text" id="gender_options" class="form-control" value="男, 女, 其他" placeholder="以逗號分隔">
            </div>

            <div class="settings-group">
                <h4>尊稱選項</h4>
                <input type="text" id="title_options" class="form-control" value="先生, 女士, 博士, 教授" placeholder="以逗號分隔">
            </div>

            <div class="settings-group">
                <h4>📊 人數限制</h4>
                <div class="form-row">
                    <div class="form-group">
                        <label for="max_participants">人數上限</label>
                        <input type="number" id="max_participants" class="form-control" min="0" value="{{project.max_participants}}" placeholder="0 = 無限制">
                        <small class="form-text text-muted">設為 0 表示不限制人數</small>
                    </div>
                    <div class="form-group">
                        <label>目前報名人數</label>
                        <div class="participant-stats">
                            <span class="stat-value" id="current_participants">{{project.current_participants}}</span>
                            <span class="stat-label">/ {{#if project.max_participants}}{{project.max_participants}}{{else}}∞{{/if}}</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="settings-group">
                <h4>📅 報名截止時間</h4>
                <div class="form-group">
                    <input type="datetime-local" id="registration_deadline" class="form-control" value="{{project.registration_deadline}}">
                    <small class="form-text text-muted">留空表示不設定截止時間</small>
                </div>
            </div>
        </div>
    </div>

    {{#if features.questionnaires}}
    <!-- 問卷狀況 -->
    <div class="tab-content" id="questionnaires-tab">
        <div class="section-header">
            <h3>問卷填寫狀況</h3>
            <div class="section-actions">
                <button class="btn btn-primary" onclick="createQuestionnaire()">
                    <i class="fas fa-plus"></i> 新建問卷
                </button>
            </div>
        </div>

        <div id="questionnaires-content">
            <div class="loading">載入問卷資料中...</div>
        </div>
    </div>
    {{/if}}

    <!-- 簽到管理 -->
    <div class="tab-content" id="checkin-tab">
        <div class="section-header">
            <h3>簽到管理</h3>
            <div class="section-actions">
                <button class="btn btn-warning" onclick="bulkCheckin()">
                    <i class="fas fa-users"></i> 批量簽到
                </button>
            </div>
        </div>

        <div class="checkin-stats" id="checkin-stats">
            <div class="loading">載入簽到統計中...</div>
        </div>

        <div class="checkin-list" id="checkin-list">
            <div class="loading">載入簽到記錄中...</div>
        </div>
    </div>

    <!-- 參加者追蹤 -->
    <div class="tab-content" id="tracking-tab">
        <div class="section-header">
            <h3>參加者追蹤</h3>
            <div class="search-box">
                <input type="text" id="tracking-search" placeholder="輸入參加者姓名或 Trace ID">
                <button class="btn btn-primary" onclick="searchTracking()">
                    <i class="fas fa-search"></i> 搜尋
                </button>
            </div>
        </div>

        <div id="tracking-results">
            <div class="tracking-placeholder">
                <i class="fas fa-search"></i>
                <p>請搜尋參加者以查看追蹤資訊</p>
            </div>
        </div>
    </div>

    {{#if features.businessCards}}
    <!-- QR Code 名片 -->
    <div class="tab-content" id="business-cards-tab">
        <div class="section-header">
            <h3>QR Code 名片管理</h3>
            <div class="section-actions">
                <button class="btn btn-success" onclick="exportBusinessCards()">
                    <i class="fas fa-download"></i> 匯出名片
                </button>
                <button class="btn btn-secondary" onclick="refreshBusinessCards()">
                    <i class="fas fa-sync-alt"></i> 重新整理
                </button>
            </div>
        </div>

        <!-- 搜尋和篩選 -->
        <div class="filter-section">
            <div class="search-box">
                <input type="text" id="business-card-search" placeholder="搜尋姓名、公司或電子郵件..." class="form-control">
                <button class="btn btn-primary" onclick="searchBusinessCards()">
                    <i class="fas fa-search"></i> 搜尋
                </button>
            </div>
        </div>

        <!-- 名片列表 -->
        <div class="business-cards-container">
            <div class="table-responsive">
                <table class="table table-striped" id="business-cards-table">
                    <thead>
                        <tr>
                            <th>姓名</th>
                            <th>職稱</th>
                            <th>公司</th>
                            <th>聯絡方式</th>
                            <th>掃描次數</th>
                            <th>建立時間</th>
                            <th>狀態</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody id="business-cards-tbody">
                        <!-- 動態載入名片資料 -->
                    </tbody>
                </table>
            </div>

            <!-- 分頁 -->
            <div class="pagination-container" id="business-cards-pagination">
                <!-- 動態載入分頁 -->
            </div>
        </div>

        <!-- 載入中指示器 -->
        <div class="loading-indicator" id="business-cards-loading" style="display: none;">
            <div class="spinner"></div>
            <p>載入中...</p>
        </div>
    </div>
    {{/if}}

    {{#if features.booths}}
    <!-- 攤位設定 -->
    <div class="tab-content" id="booths-tab">
        <div class="section-header">
            <h3>攤位設定</h3>
            <div class="section-actions">
                <button class="btn btn-success" onclick="addBoothModal()">
                    <i class="fas fa-plus"></i> 新增攤位
                </button>
                <button class="btn btn-secondary" onclick="refreshBooths()">
                    <i class="fas fa-sync-alt"></i> 重新整理
                </button>
            </div>
        </div>

        <div class="data-table-container">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>攤位名稱</th>
                            <th>代碼</th>
                            <th>位置</th>
                            <th>狀態</th>
                            <th>綁定遊戲</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody id="project-booths-table">
                        <tr>
                            <td colspan="7" class="text-center">
                                <div class="spinner"></div>
                                <p>載入中...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {{/if}}

    {{#if features.games}}
    <!-- 遊戲設定 -->
    <div class="tab-content" id="games-tab">
        <div class="section-header">
            <h3>遊戲設定</h3>
            <div class="section-actions">
                <button class="btn btn-success" onclick="bindGameModal()">
                    <i class="fas fa-plus"></i> 綁定遊戲
                </button>
                <button class="btn btn-secondary" onclick="refreshProjectGames()">
                    <i class="fas fa-sync-alt"></i> 重新整理
                </button>
            </div>
        </div>

        <div class="data-table-container">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>遊戲名稱</th>
                            <th>狀態</th>
                            <th>關聯兌換券</th>
                            <th>庫存</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody id="project-games-table">
                        <tr>
                            <td colspan="7" class="text-center">
                                <div class="spinner"></div>
                                <p>載入中...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {{/if}}

    <!-- 郵件管理 Tab -->
    <div class="tab-content" id="email-management-tab">
        <div class="section-header">
            <h3>📧 郵件管理</h3>
        </div>

        <!-- Sub-tabs 導航 -->
        <div class="sub-tabs">
            <button class="sub-tab-btn active" data-subtab="registration-email">📩 報名確認信</button>
            <button class="sub-tab-btn" data-subtab="pre-event-email">📨 行前通知</button>
            <button class="sub-tab-btn" data-subtab="email-templates">📋 Email 模板預覽</button>
        </div>

        <!-- Sub-tab 1: 報名確認信 -->
        <div class="sub-tab-content active" id="registration-email-subtab">
            <div class="subtab-header">
                <h4>報名確認信（重寄邀請信）</h4>
                <div class="section-actions">
                    <button class="btn btn-success" id="btn-resend-selected" onclick="resendRegistrationEmailToSelected()" disabled>
                        <i class="fas fa-paper-plane"></i> 重寄選取 (<span id="resend-selected-count">0</span>)
                    </button>
                    <button class="btn btn-secondary" onclick="loadRegistrationRecipients()">
                        <i class="fas fa-sync-alt"></i> 重新整理
                    </button>
                </div>
            </div>

            <!-- 統計資訊 -->
            <div class="stats-grid-inline" style="margin-bottom: 1rem;">
                <div class="stat-card-inline primary">
                    <div class="stat-value" id="reg-email-total">-</div>
                    <div class="stat-label">總報名人數</div>
                </div>
                <div class="stat-card-inline info">
                    <div class="stat-value" id="reg-email-group-count">-</div>
                    <div class="stat-label">團體報名組數</div>
                </div>
            </div>

            <!-- 篩選器 -->
            <div class="filter-bar-inline" style="margin-bottom: 1rem;">
                <input type="text" id="reg-email-search" class="form-control" placeholder="搜尋姓名或 Email..." style="max-width: 250px;">
                <label style="margin-left: 1rem;">
                    <input type="checkbox" id="reg-email-group-only"> 僅顯示團體報名
                </label>
                <button class="btn btn-primary btn-sm" onclick="loadRegistrationRecipients()" style="margin-left: 0.5rem;">
                    <i class="fas fa-search"></i> 查詢
                </button>
            </div>

            <!-- 收件者列表 -->
            <div class="data-table-container">
                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th style="width: 40px;"><input type="checkbox" id="select-all-reg" onchange="toggleSelectAllRegistration()"></th>
                                <th>ID</th>
                                <th>姓名</th>
                                <th>Email</th>
                                <th>電話</th>
                                <th>類型</th>
                                <th>報名時間</th>
                                <th style="width: 100px;">操作</th>
                            </tr>
                        </thead>
                        <tbody id="reg-email-tbody">
                            <tr>
                                <td colspan="8" class="text-center">
                                    <div class="spinner"></div>
                                    <p>載入中...</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Sub-tab 2: 行前通知 -->
        <div class="sub-tab-content" id="pre-event-email-subtab">
            <div class="subtab-header">
                <h4>行前通知郵件</h4>
                <div class="section-actions">
                    <button class="btn btn-success" id="btn-send-selected" onclick="sendPreEventEmailToSelected()" disabled>
                        <i class="fas fa-paper-plane"></i> 發送給選取 (<span id="selected-count">0</span>)
                    </button>
                    <button class="btn btn-primary" id="btn-send-pre-event-email" onclick="sendPreEventEmail()">
                        <i class="fas fa-paper-plane"></i> 發送給全部
                    </button>
                    <button class="btn btn-secondary" onclick="loadPreEventRecipients()">
                        <i class="fas fa-sync-alt"></i> 重新整理
                    </button>
                </div>
            </div>

            <!-- 統計資訊 -->
            <div class="stats-grid-inline" style="margin-bottom: 1.5rem;">
                <div class="stat-card-inline primary">
                    <div class="stat-value" id="pre-event-total">-</div>
                    <div class="stat-label">可發送人數</div>
                </div>
                <div class="stat-card-inline info">
                    <div class="stat-value" id="pre-event-has-email">-</div>
                    <div class="stat-label">有 Email</div>
                </div>
            </div>

            <!-- 收件者列表 -->
            <div class="data-table-container">
                <h4 style="margin-bottom: 1rem;">收件者列表 <small class="text-muted">（勾選後可單獨發送）</small></h4>
                <div class="table-responsive">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th style="width: 40px;"><input type="checkbox" id="select-all-recipients" onchange="toggleSelectAllRecipients()"></th>
                                <th>姓名</th>
                                <th>Email</th>
                                <th>電話</th>
                                <th>報名時間</th>
