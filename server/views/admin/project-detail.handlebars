        .filter-bar-inline {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1rem;
            background: #f8f9fa;
            border-radius: 8px;
        }

        .template-selector {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .template-btn {
            transition: all 0.2s;
        }

        .template-btn.active {
            background: #007bff;
