<div class="container-fluid">
    <div class="page-header">
        <h1>攤位管理</h1>
        <div class="page-actions">
            <button class="btn btn-primary" id="new-booth-btn">
                <i class="fas fa-plus"></i> 新增攤位
            </button>
            <button class="btn btn-secondary" onclick="loadBooths()">
                <i class="fas fa-sync-alt"></i> 重新整理
            </button>
        </div>
    </div>

    <!-- 篩選器 -->
    <div class="filter-section">
        <div class="form-row">
            <div class="form-group col-md-4">
                <label>專案篩選</label>
                <select class="form-control" id="project-filter">
                    <option value="">全部專案</option>
                </select>
            </div>
        </div>
    </div>

    <!-- 攤位列表 -->
    <div class="card">
        <div class="card-body">
            <div id="booths-table-container">
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="sr-only">載入中...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 模態框容器 -->
<div id="modal-container"></div>

<style>
.booth-status {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
}

.booth-status.active {
    background-color: #d4edda;
    color: #155724;
}

.booth-status.inactive {
    background-color: #f8d7da;
    color: #721c24;
}

.booth-code {
    font-family: 'Courier New', monospace;
    background-color: #f8f9fa;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 13px;
}

/* Modal 樣式 */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
}

.modal-dialog {
    background: white;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    max-width: 600px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
}

.modal-header {
    padding: 20px;
    border-bottom: 1px solid #dee2e6;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.modal-header h3 {
    margin: 0;
    font-size: 1.25rem;
}

.modal-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #6c757d;
    padding: 0;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.modal-close:hover {
    color: #000;
}

.modal-body {
    padding: 20px;
}

.modal-footer {
    padding: 15px 20px;
    border-top: 1px solid #dee2e6;
    display: flex;
    justify-content: flex-end;
    gap: 10px;
}
</style>

<script>
let allBooths = [];
let allProjects = [];

// 頁面載入時執行
document.addEventListener('DOMContentLoaded', function() {
    loadProjects();
    loadBooths();
    
    // 新增攤位按鈕
    document.getElementById('new-booth-btn').addEventListener('click', function() {
        showBoothModal();
    });
    
    // 專案篩選
    document.getElementById('project-filter').addEventListener('change', function() {
        filterBooths();
    });
});

// 載入專案列表
async function loadProjects() {
    try {
        const response = await fetch('/api/admin/projects');
        const data = await response.json();

        if (data.success && data.data) {
            allProjects = data.data;

            const select = document.getElementById('project-filter');
            select.innerHTML = '<option value="">全部專案</option>';

            if (allProjects && allProjects.length > 0) {
                allProjects.forEach(project => {
                    const option = document.createElement('option');
                    option.value = project.id;
                    option.textContent = project.project_name;
                    select.appendChild(option);
                });
            }
        }
    } catch (error) {
        console.error('載入專案列表失敗:', error);
    }
}

// 載入攤位列表
async function loadBooths() {
    try {
        const projectId = document.getElementById('project-filter').value;
        const url = projectId ? `/admin/booths/api/list?project_id=${projectId}` : '/admin/booths/api/list';

        const response = await fetch(url);
        const data = await response.json();

        if (data.success && data.data && data.data.booths) {
            allBooths = data.data.booths;
            renderBoothsTable(allBooths);
        } else {
            // 沒有資料時顯示空狀態
            allBooths = [];
            renderBoothsTable([]);
        }
    } catch (error) {
        console.error('載入攤位列表失敗:', error);
        // 錯誤時也顯示空狀態
        allBooths = [];
        renderBoothsTable([]);
    }
}

// 篩選攤位
function filterBooths() {
    loadBooths();
}

// 渲染攤位表格
function renderBoothsTable(booths) {
    const container = document.getElementById('booths-table-container');
    
    if (booths.length === 0) {
        container.innerHTML = '<p class="text-center text-muted">目前沒有攤位資料</p>';
        return;
    }
    
    let html = `
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>攤位名稱</th>
                    <th>攤位代碼</th>
                    <th>專案</th>
                    <th>位置</th>
                    <th>玩家數</th>
                    <th>會話數</th>
                    <th>狀態</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
    `;
    
    booths.forEach(booth => {
        const statusClass = booth.is_active ? 'active' : 'inactive';
        const statusText = booth.is_active ? '啟用' : '停用';
        
        html += `
            <tr>
                <td>${booth.id}</td>
                <td><strong>${booth.booth_name}</strong></td>
                <td><span class="booth-code">${booth.booth_code}</span></td>
                <td>${booth.project_name || '-'}</td>
                <td>${booth.location || '-'}</td>
                <td>${booth.player_count || 0}</td>
                <td>${booth.session_count || 0}</td>
                <td><span class="booth-status ${statusClass}">${statusText}</span></td>
                <td>
                    <button class="btn btn-sm btn-info" onclick="viewBoothStats(${booth.id})">
                        <i class="fas fa-chart-bar"></i> 統計
                    </button>
                    <button class="btn btn-sm btn-primary" onclick="editBooth(${booth.id})">
                        <i class="fas fa-edit"></i> 編輯
                    </button>
                    <button class="btn btn-sm btn-danger" onclick="deleteBooth(${booth.id})">
                        <i class="fas fa-trash"></i> 刪除
                    </button>
                </td>
            </tr>
        `;
    });
    
    html += `
            </tbody>
        </table>
    `;
    
    container.innerHTML = html;
}

// 顯示攤位模態框（新增或編輯）
function showBoothModal(boothId = null) {
    const isEdit = boothId !== null;
    const title = isEdit ? '編輯攤位' : '新增攤位';
    
    let modalHtml = `
        <div class="modal-overlay" id="booth-modal">
            <div class="modal-dialog">
                <div class="modal-header">
                    <h3>${title}</h3>
                    <button class="modal-close" onclick="closeModal()">&times;</button>
                </div>
                <div class="modal-body">
                    <form id="booth-form">
                        <div class="form-group">
                            <label>專案 *</label>
                            <select class="form-control" id="booth-project-id" required>
                                <option value="">請選擇專案</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>攤位名稱 *</label>
                            <input type="text" class="form-control" id="booth-name" required>
                        </div>
                        <div class="form-group">
                            <label>攤位代碼 *</label>
                            <input type="text" class="form-control" id="booth-code" required placeholder="例: BOOTH-A1">
                        </div>
                        <div class="form-group">
                            <label>位置</label>
                            <input type="text" class="form-control" id="booth-location" placeholder="例: 展場 A 區入口處">
                        </div>
                        <div class="form-group">
                            <label>描述</label>
                            <textarea class="form-control" id="booth-description" rows="3"></textarea>
                        </div>
                        ${isEdit ? `
                        <div class="form-group">
                            <label>
                                <input type="checkbox" id="booth-is-active"> 啟用
                            </label>
                        </div>
                        ` : ''}
                    </form>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" onclick="closeModal()">取消</button>
                    <button class="btn btn-primary" onclick="saveBooth(${boothId})">儲存</button>
                </div>
            </div>
        </div>
    `;
    
    document.getElementById('modal-container').innerHTML = modalHtml;
    
    // 填充專案選項
    const projectSelect = document.getElementById('booth-project-id');
    allProjects.forEach(project => {
        const option = document.createElement('option');
        option.value = project.id;
        option.textContent = project.project_name;
        projectSelect.appendChild(option);
    });
    
    // 如果是編輯模式，載入攤位資料
    if (isEdit) {
        loadBoothData(boothId);
    }
}

// 載入攤位資料（編輯模式）
async function loadBoothData(boothId) {
    try {
        const response = await fetch(`/admin/booths/api/${boothId}`);
        const data = await response.json();
        
        if (data.success) {
            const booth = data.data.booth;
            document.getElementById('booth-project-id').value = booth.project_id;
            document.getElementById('booth-name').value = booth.booth_name;
            document.getElementById('booth-code').value = booth.booth_code;
            document.getElementById('booth-location').value = booth.location || '';
            document.getElementById('booth-description').value = booth.description || '';
            document.getElementById('booth-is-active').checked = booth.is_active;
        }
    } catch (error) {
        console.error('載入攤位資料失敗:', error);
    }
}

// 儲存攤位
async function saveBooth(boothId) {
    const projectId = document.getElementById('booth-project-id').value;
    const boothName = document.getElementById('booth-name').value.trim();
    const boothCode = document.getElementById('booth-code').value.trim();
    const location = document.getElementById('booth-location').value.trim();
    const description = document.getElementById('booth-description').value.trim();
    
    if (!projectId || !boothName || !boothCode) {
        showNotification('請填寫所有必填欄位', 'error');
        return;
    }
    
    const data = {
        project_id: parseInt(projectId),
        booth_name: boothName,
        booth_code: boothCode,
        location,
        description
    };
    
    if (boothId) {
        data.is_active = document.getElementById('booth-is-active').checked;
    }
    
    const url = boothId ? `/admin/booths/api/${boothId}` : '/admin/booths/api';
    const method = boothId ? 'PUT' : 'POST';
    
    try {
        const response = await fetch(url, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            showNotification(result.message, 'success');
            closeModal();
            loadBooths();
        } else {
            showNotification(result.message || '儲存失敗', 'error');
        }
    } catch (error) {
        console.error('儲存攤位失敗:', error);
        showNotification('儲存攤位失敗', 'error');
    }
}

// 編輯攤位
function editBooth(boothId) {
    showBoothModal(boothId);
}

// 刪除攤位
async function deleteBooth(boothId) {
    if (!confirm('確定要刪除此攤位嗎？')) {
        return;
    }
    
    try {
        const response = await fetch(`/admin/booths/api/${boothId}`, {
            method: 'DELETE'
        });
        
        const data = await response.json();
        
        if (data.success) {
            showNotification(data.message, 'success');
            loadBooths();
        } else {
            showNotification(data.message || '刪除失敗', 'error');
        }
    } catch (error) {
        console.error('刪除攤位失敗:', error);
        showNotification('刪除攤位失敗', 'error');
    }
}

// 查看攤位統計
function viewBoothStats(boothId) {
    window.location.href = `/admin/booths/${boothId}/stats`;
}

// 關閉模態框
function closeModal() {
    document.getElementById('modal-container').innerHTML = '';
}

// 顯示通知
function showNotification(message, type = 'info') {
    alert(message);
}
</script>

