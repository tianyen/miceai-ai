<div class="container-fluid">
    <div class="page-header">
        <h1>攤位管理</h1>
        <div class="page-actions">
            <button class="btn btn-primary" id="new-booth-btn">
                <i class="fas fa-plus"></i> 新增攤位
            </button>
            <button class="btn btn-secondary" onclick="loadBooths()">
                <i class="fas fa-sync-alt"></i> 重新整理
            </button>
        </div>
    </div>

    <!-- 篩選器 -->
    <div class="filter-section">
        <div class="form-row">
            <div class="form-group col-md-4">
                <label>專案篩選</label>
                <select class="form-control" id="project-filter">
                    <option value="">全部專案</option>
                </select>
            </div>
        </div>
    </div>

    <!-- 攤位列表 -->
    <div class="card">
        <div class="card-body">
            <div id="booths-table-container">
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="sr-only">載入中...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 模態框容器 -->
<div id="modal-container"></div>

{{!-- External CSS/JS loaded via additionalCSS and additionalJS in route --}}

