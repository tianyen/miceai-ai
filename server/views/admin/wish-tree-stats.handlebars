{{!-- 許願樹統計頁面 --}}

<div class="page-header">
    <div>
        <h1>許願樹統計分析</h1>
        <p class="text-muted">{{project.project_name}} - 互動數據分析與高峰頻率統計</p>
    </div>
    <div class="header-actions">
        <a href="/admin/wish-tree/export-csv?project_id={{currentProjectId}}"
           class="btn btn-success"
           download
           title="匯出所有許願記錄為 CSV 檔案">
            匯出 CSV
        </a>
        <a href="/admin/wish-tree/list?project_id={{currentProjectId}}" class="btn btn-primary">
            查看列表
        </a>
    </div>
</div>

<!-- 專案選擇與日期篩選 -->
<div class="filter-section">
    <form method="GET" action="/admin/wish-tree/stats">
        <div class="form-group">
            <label>選擇專案:</label>
            <select name="project_id" class="form-control" onchange="this.form.submit()">
                {{#each projects}}
                <option value="{{this.id}}" {{#if (eq this.id ../currentProjectId)}}selected{{/if}}>
                    {{this.project_name}} ({{this.project_code}})
                </option>
                {{/each}}
            </select>
        </div>
    </form>

    <!-- 日期範圍選擇器 -->
    <div class="date-filter-section">
        <label>查看範圍:</label>
        <div class="date-filter-buttons">
            <button class="filter-btn active" data-range="today">今日</button>
            <button class="filter-btn" data-range="yesterday">昨日</button>
            <button class="filter-btn" data-range="week">本週</button>
            <button class="filter-btn" data-range="all">全部</button>
        </div>
        <div class="date-range-display" id="dateRangeDisplay">
            <span id="dateRangeText">今日</span>
        </div>
    </div>
</div>

<!-- 統計卡片 -->
<div class="stats-grid" id="stats-grid">
    <div class="stat-card primary">
        <div class="stat-value" id="total-wishes">-</div>
        <div class="stat-label">總許願數</div>
    </div>

    <div class="stat-card success">
        <div class="stat-value" id="today-wishes">-</div>
        <div class="stat-label">今日許願</div>
    </div>

    <div class="stat-card warning">
        <div class="stat-value" id="peak-hour">-</div>
        <div class="stat-label">最高峰時段</div>
    </div>

    <div class="stat-card info">
        <div class="stat-value" id="avg-per-hour">-</div>
        <div class="stat-label">平均每小時</div>
    </div>
</div>

<!-- 圖表區域 -->
<div class="dashboard-grid">
    <!-- 時間點分佈圖 -->
    <div class="dashboard-card full-width">
        <div class="card-header">
            <h3>許願時間點分佈</h3>
            <span class="badge">即時更新</span>
        </div>
        <div class="card-content">
            <canvas id="timelineChart" height="300"></canvas>
        </div>
    </div>

    <!-- 每小時分佈圖 -->
    <div class="dashboard-card full-width">
        <div class="card-header">
            <h3>每小時互動分佈</h3>
        </div>
        <div class="card-content">
            <canvas id="hourlyChart" height="300"></canvas>
        </div>
    </div>

    <!-- 每日分佈圖 -->
    <div class="dashboard-card full-width">
        <div class="card-header">
            <h3>每日互動趨勢</h3>
        </div>
        <div class="card-content">
            <canvas id="dailyChart" height="300"></canvas>
        </div>
    </div>

    <!-- 高峰時段排行 -->
    <div class="dashboard-card">
        <div class="card-header">
            <h3>高峰時段 Top 5</h3>
        </div>
        <div class="card-content">
            <table class="data-table" id="peak-hours-table">
                <thead>
                    <tr>
                        <th>排名</th>
                        <th>時段</th>
                        <th>互動數</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="3" class="text-center">載入中...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- 最近許願 -->
    <div class="dashboard-card">
        <div class="card-header">
            <h3>最近許願</h3>
            <a href="/admin/wish-tree/list?project_id={{currentProjectId}}" class="btn btn-sm btn-primary">
                查看全部
            </a>
        </div>
        <div class="card-content" id="recent-wishes">
            <p class="text-center text-muted">載入中...</p>
        </div>
    </div>
</div>

<!-- 引入 Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>

<!-- 橋接腳本：傳遞 Handlebars 變數給外部 JavaScript -->
<script>
    window.wishTreeProjectId = {{currentProjectId}};
</script>

{{!-- External CSS/JS loaded via additionalCSS and additionalJS in route --}}
