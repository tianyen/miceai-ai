{
  "name": "invitation-admin-system",
  "version": "1.0.0",
  "description": "Complete invitation management system with admin panel - Modular Version",
  "main": "server-new.js",
  "scripts": {
    "start": "node server-new.js",
    "start:legacy": "node server.js",
    "dev": "nodemon server-new.js",
    "dev:legacy": "nodemon server.js",
    "test": "node test-modular.js",
    "db:setup": "node database/setup.js",
    "db:seed": "node database/seed.js",
    "db:init": "node scripts/init-database.js",
    "db:reset": "node scripts/db-reset.js",
    "db:seed-data": "node scripts/db-seed.js",
    "db:info": "node scripts/db-info.js", 
    "db:check": "node scripts/check-database.js",
    "generate-certs": "mkdir -p certs && openssl req -x509 -newkey rsa:4096 -keyout certs/key.pem -out certs/cert.pem -days 365 -nodes -subj \"/C=TW/ST=Taiwan/L=Taipei/O=MICE-AI/OU=Development/CN=localhost\""
  },
  "keywords": [
    "express",
    "invitation",
    "admin",
    "management",
    "modular",
    "mvc"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-handlebars": "^7.1.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "jquery": "^3.7.1",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
