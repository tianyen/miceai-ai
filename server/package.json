{
  "name": "mice-ai-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "production": "NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
    "test": "node test-modular.js",
    "verify": "bash scripts/verify-all.sh",
    "verify:migration": "node scripts/verify-migration.js",
    "verify:api": "node scripts/test-api-v1-endpoints.js",
    "verify:api:http": "node scripts/test-api-v1-http.js",
    "verify:data": "node scripts/check-data-flow.js",
    "verify:workflow": "node scripts/test-full-workflow.js",
    "verify:admin": "node scripts/check-admin-data.js",
    "verify:batch-registration": "node scripts/verify-batch-registration.js",
    "verify:group-full-flow": "node scripts/verify-group-full-flow.js",
    "verify:children-stats": "node scripts/verify-children-stats.js",
    "verify:pj0132:unit": "node scripts/test-game-flow-service-unit.js",
    "verify:pj0132:public": "node scripts/verify-pj0132-mobile-flows-public.js",
    "verify:pj0132:admin": "node scripts/verify-pj0132-admin-analytics.js",
    "verify:pj0132:all": "npm run verify:pj0132:unit && npm run verify:pj0132:public && npm run verify:pj0132:admin",
    "verify:pj0132:public:remote": "PJ0132_INSECURE_TLS=1 node scripts/verify-pj0132-mobile-flows-public.js",
    "verify:pj0132:admin:remote": "PJ0132_INSECURE_TLS=1 node scripts/verify-pj0132-admin-analytics.js",
    "verify:pj0132:all:remote": "npm run verify:pj0132:unit && npm run verify:pj0132:public:remote && npm run verify:pj0132:admin:remote",
    "verify:pj0132:public:vps-local": "API_URL=http://127.0.0.1:9994/api/v1 node scripts/verify-pj0132-mobile-flows-public.js",
    "verify:pj0132:admin:vps-local": "BASE_URL=http://127.0.0.1:9994 ADMIN_BASE_URL=http://127.0.0.1:9994 node scripts/verify-pj0132-admin-analytics.js",
    "verify:pj0132:all:vps-local": "npm run verify:pj0132:unit && npm run verify:pj0132:public:vps-local && npm run verify:pj0132:admin:vps-local",
    "verify:pj0132:regression:happy": "PJ0132_FLOW_MODE=happy node scripts/verify-pj0132-mobile-flows-public.js",
    "verify:pj0132:regression:failure": "PJ0132_FLOW_MODE=failure node scripts/verify-pj0132-mobile-flows-public.js",
    "verify:pj0132:regression:upload-fail": "PJ0132_FLOW_MODE=upload-fail node scripts/verify-pj0132-mobile-flows-public.js",
    "verify:pj0132:regression:alias": "PJ0132_FLOW_MODE=alias node scripts/verify-pj0132-mobile-flows-public.js",
    "verify:timezone": "node scripts/verify-timezone.js",
    "test:api": "bash scripts/test-api-flow.sh",
    "test:setup": "bash scripts/test-setup.sh",
    "test:business-cards": "node scripts/test-business-cards.js",
    "db:init": "node scripts/init-database.js",
    "db:reset": "node scripts/db-reset.js",
    "db:seed": "node scripts/db-seed.js",
    "db:info": "node scripts/db-info.js",
    "db:check": "node scripts/check-database.js",
    "db:verify": "node scripts/verify-schema.js",
    "db:verify-paths": "node scripts/verify-db-paths.js",
    "db:migrate": "node scripts/deprecated-migration.js db:migrate",
    "db:migrate:gameroom": "node scripts/deprecated-migration.js db:migrate:gameroom",
    "db:migrate:booths": "node scripts/deprecated-migration.js db:migrate:booths",
    "db:migrate:wishtree": "node scripts/deprecated-migration.js db:migrate:wishtree",
    "db:migrate:add-user-id": "node scripts/deprecated-migration.js db:migrate:add-user-id",
    "db:migrate:form-config": "node scripts/deprecated-migration.js db:migrate:form-config",
    "db:seed:gameroom": "node scripts/seed-game-room.js",
    "db:seed:mobile-games": "node scripts/seed-mobile-games.js",
    "db:seed:questionnaire": "node scripts/seed-sample-questionnaire.js",
    "db:seed:wishtree": "node scripts/seed-wish-tree.js",
    "db:seed:game-analytics": "node scripts/seed-game-analytics-data.js",
    "db:seed:demo": "node scripts/seed-demo-2026.js",
    "db:clean:p0-indexes": "node scripts/cleanup-p0-index-conflicts.js",
    "db:clean:test-users": "node scripts/cleanup-test-users.js",
    "test:swagger": "bash scripts/test-swagger-examples.sh",
    "generate:qrcodes": "node scripts/generate-test-qrcode.js",
    "generate:registration-qrcode": "node scripts/generate-registration-qrcode.js",
    "pre-setup": "node scripts/pre-setup.js",
    "setup": "npm run pre-setup && npm run db:reset && npm run db:seed && npm run db:seed:mobile-games && npm run db:seed:gameroom && npm run db:seed:questionnaire && npm run db:seed:wishtree && npm run db:seed:game-analytics && npm run db:seed:demo && npm run generate:qrcodes && npm run generate:registration-qrcode && npm run verify && npm run db:clean:test-users",
    "setup:poc": "npm run db:reset && npm run db:seed && npm run db:seed:mobile-games && npm run db:seed:gameroom && npm run db:seed:questionnaire && npm run db:seed:game-analytics && npm run generate:qrcodes && npm run generate:registration-qrcode",
    "analyze:imports": "node scripts/analyze-unused-imports.js",
    "logs": "node scripts/view-logs.js",
    "logs:4xx": "node scripts/view-logs.js 4xx_errors_$(date +%Y-%m-%d).log",
    "logs:5xx": "node scripts/view-logs.js 5xx_errors_$(date +%Y-%m-%d).log",
    "logs:info": "node scripts/view-logs.js info_$(date +%Y-%m-%d).log",
    "logs:error": "node scripts/view-logs.js error_$(date +%Y-%m-%d).log",
    "logs:business": "node scripts/view-logs.js business_$(date +%Y-%m-%d).log",
    "logs:security": "node scripts/view-logs.js security_$(date +%Y-%m-%d).log",
    "migrate:logger": "node scripts/migrate-to-logger.js",
    "migrate:logger:dry": "node scripts/migrate-to-logger.js --dry-run",
    "backup": "node -e \"const config=require('./config'); const fs=require('fs'); const path=require('path'); const src=path.resolve(config.database.path); const dest=src.replace('.db', '_backup_'+new Date().toISOString().replace(/[:.]/g,'-')+'.db'); fs.copyFileSync(src,dest); console.log('Database backed up to:', dest);\"",
    "status": "npm run db:info && echo '\\n=== Server Status ===' && ps aux | grep 'node server.js' | grep -v grep || echo 'Server not running'",
    "generate-certs": "mkdir -p certs && openssl req -x509 -newkey rsa:4096 -keyout certs/key.pem -out certs/cert.pem -days 365 -nodes -subj \"/C=TW/ST=Taiwan/L=Taipei/O=MICE-AI/OU=Development/CN=localhost\""
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.5.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^4.18.2",
    "express-handlebars": "^7.1.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "jquery": "^3.7.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.11",
    "qrcode": "^1.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}
